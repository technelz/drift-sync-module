def plan_summary(plan: SgPlan) -> Dict[str, Any]:
    return {
        "total_source_sgs": plan.total,
        "in_sync": plan.in_sync_count,
        "strict_matches": plan.strict_matches,
        "legacy_matches": plan.legacy_matches,
        "missing_in_target": plan.missing_count,
        "drifted_sgs": plan.drift_count,
        "unresolved_dependencies": plan.unresolved_dependency_count,
        "duplicate_canonical_keys": len(plan.duplicate_canonical_keys),
    }


def human_readable_summary(plan: SgPlan) -> Dict[str, Any]:
    return {
        "source_security_groups": [
            match.source_name
            for match in plan.matches
        ],
        "matched_security_groups": [
            {
                "source_name": match.source_name,
                "source_id": match.source_id,
                "target_name": match.target_name,
                "target_id": match.target_id,
                "match_confidence": match.match_confidence,
                "matched_via": match.matched_via,
                "canonical_name": match.canonical_name,
            }
            for match in plan.matches
            if match.target_id
        ],
        "missing_in_target": [
            {
                "source_name": match.source_name,
                "source_id": match.source_id,
                "canonical_name": match.canonical_name,
                "reason": match.strict_reason,
            }
            for match in plan.missing
        ],
        "drifted_security_groups": [
            {
                "group_name": drift.group_name,
                "source_group_id": drift.source_group_id,
                "target_group_id": drift.target_group_id,
                "match_confidence": drift.match.match_confidence,
                "matched_via": drift.match.matched_via,
                "missing_ingress_count": len(drift.missing_ingress),
                "extra_ingress_count": len(drift.extra_ingress),
                "missing_egress_count": len(drift.missing_egress),
                "extra_egress_count": len(drift.extra_egress),
                "tag_drift": drift.tag_drift,
                "tag_diff_count": drift.tag_diff_count,
                "description_drift": drift.description_drift,
                "planned_actions": build_planned_actions_for_drift(drift),
            }
            for drift in plan.drifts
        ],
        "unresolved_dependencies": [
            {
                "source_group_name": issue.source_group_name,
                "source_group_id": issue.source_group_id,
                "direction": issue.direction,
                "referenced_source_group_id": issue.referenced_source_group_id,
                "referenced_group_name": issue.referenced_group_name,
                "reason": issue.reason,
            }
            for issue in plan.unresolved_dependencies
        ],
        "duplicate_canonical_keys": plan.duplicate_canonical_keys,
    }


def build_planned_actions_for_drift(drift: SgDrift) -> List[str]:
    actions: List[str] = []

    if drift.tag_drift:
        actions.append("Sync tags")

    if drift.description_drift:
        actions.append(
            "Description drift detected; AWS does not support direct SG description update"
        )

    if drift.missing_ingress:
        actions.append(f"Add {len(drift.missing_ingress)} ingress rule(s)")

    if drift.extra_ingress:
        actions.append(
            f"Remove {len(drift.extra_ingress)} extra ingress rule(s) if --revoke-extra-rules is used"
        )

    if drift.missing_egress:
        actions.append(f"Add {len(drift.missing_egress)} egress rule(s)")

    if drift.extra_egress:
        actions.append(
            f"Remove {len(drift.extra_egress)} extra egress rule(s) if --revoke-extra-rules is used"
        )

    if not actions:
        actions.append("No changes required")

    return actions


def write_report(report_path: str, plan: SgPlan, mode: str) -> None:
    os.makedirs(os.path.dirname(report_path) or ".", exist_ok=True)

    payload = {
        "generated_at_utc": datetime.utcnow().strftime("%Y-%m-%d %H:%M:%S"),
        "mode": mode,
        "summary": plan_summary(plan),
        "human_readable_summary": human_readable_summary(plan),
        "matches": [asdict(match) for match in plan.matches],
        "drifts": [asdict(drift) for drift in plan.drifts],
        "missing": [asdict(match) for match in plan.missing],
        "unresolved_dependencies": [
            asdict(issue)
            for issue in plan.unresolved_dependencies
        ],
        "duplicate_canonical_keys": plan.duplicate_canonical_keys,
    }

    with open(report_path, "w", encoding="utf-8") as f:
        json.dump(payload, f, indent=2)

    log(f"[INFO] Report written to {report_path}")


