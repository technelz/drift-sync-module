def get_ec2_client(profile: Optional[str], region: Optional[str]):
    if profile:
        session = boto3.Session(profile_name=profile, region_name=region)
    else:
        session = boto3.Session(region_name=region)
    return session.client("ec2")


def load_source_sgs_from_json(path: str) -> List[Dict[str, Any]]:
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)

    if isinstance(data, list):
        groups = data
    elif isinstance(data, dict) and "SecurityGroups" in data:
        groups = data["SecurityGroups"]
    else:
        raise ValueError("Unsupported JSON structure. Expected list or {'SecurityGroups': [...]}.")

    if not isinstance(groups, list):
        raise ValueError("SecurityGroups must be a list.")

    return [sg for sg in groups if sg.get("GroupName") != "default"]


def get_sgs_for_vpc(ec2, vpc_id: str) -> List[Dict[str, Any]]:
    paginator = ec2.get_paginator("describe_security_groups")
    groups: List[Dict[str, Any]] = []

    for page in paginator.paginate(
        Filters=[{"Name": "vpc-id", "Values": [vpc_id]}]
    ):
        groups.extend(page.get("SecurityGroups", []))

    return [sg for sg in groups if sg.get("GroupName") != "default"]


# --------------------------------------------------------------------
# TAG HELPERS
# --------------------------------------------------------------------

def get_tag_value(sg: Dict[str, Any], key: str) -> Optional[str]:
    for tag in sg.get("Tags", []) or []:
        if tag.get("Key") == key:
            return tag.get("Value")
    return None


def get_name_tag(sg: Dict[str, Any]) -> Optional[str]:
    return get_tag_value(sg, "Name")


def clean_tags_for_copy(tags: List[Dict[str, str]]) -> List[Dict[str, str]]:
    cleaned = []
    for tag in tags or []:
        key = tag.get("Key")
        value = tag.get("Value", "")
        if key and key not in SYSTEM_TAG_KEYS_TO_IGNORE:
            cleaned.append({"Key": key, "Value": value})
    return cleaned


def canonical_tags(tags: List[Dict[str, str]]) -> Dict[str, str]:
    out: Dict[str, str] = {}
    for tag in tags or []:
        key = tag.get("Key")
        value = tag.get("Value", "")
        if key and key not in SYSTEM_TAG_KEYS_TO_IGNORE:
            out[key] = value
    return out


# --------------------------------------------------------------------
# NORMALIZATION / NAME DERIVATION
# --------------------------------------------------------------------

def normalize_sg_name(name: str) -> str:
    """
    Canonical name used for fallback matching.

    Strategy:
    - Prefer exact GroupName match before this is used.
    - This is only a fallback for generated suffix/prefix differences.
    - Avoid stripping meaningful terms like datasync, hnc, app, ec2servers.
    """
    raw = (name or "").strip()
    lowered = raw.lower()

    directory_match = re.search(r"(d-[a-z0-9]+)(_.*)?", lowered)
    if directory_match:
        directory_id = directory_match.group(1)
        suffix = directory_match.group(2) or ""
        return f"{directory_id}{suffix}"

    if lowered.startswith("stack-"):
        parts = [p for p in re.split(r"[-_]+", lowered) if p]
        if len(parts) >= 4:
            logical_name = parts[-2]
            return re.sub(r"[^a-z0-9]", "", logical_name)

    parts = [p for p in re.split(r"[-_]+", lowered) if p]

    if len(parts) > 1:
        last = parts[-1]
        looks_hash = (
            len(last) >= 8
            and any(c.isdigit() for c in last)
            and any(c.isalpha() for c in last)
        )
        if looks_hash:
            parts = parts[:-1]

    return re.sub(r"[^a-z0-9]", "", "".join(parts))


def derive_new_sg_name(source_name: str) -> str:
    """
    Name used when creating missing target SG shell.
    Keeps source identity as much as possible, while removing obvious CFN suffix.
    """
    raw = source_name.strip()
    parts = [p for p in raw.replace("_", "-").split("-") if p]

    if len(parts) >= 4 and parts[0].lower() == "stack":
        logical_name = parts[-2]
        return logical_name[:255]

    if len(parts) >= 2:
        last = parts[-1]
        if len(last) >= 8 and any(c.isdigit() for c in last) and any(c.isalpha() for c in last):
            return "-".join(parts[:-1])[:255]

    return raw[:255]


def extract_directory_suffix(name: str) -> Optional[str]:
    m = re.search(r"d-[A-Za-z0-9]+(_.*)", name or "")
    return m.group(1) if m else None
# --------------------------------------------------------------------
# MATCHING ENGINE
# --------------------------------------------------------------------

def build_duplicate_canonical_keys(target_groups: List[Dict[str, Any]]) -> Dict[str, List[str]]:
    bucket: Dict[str, List[str]] = {}

    for sg in target_groups:
        canon = normalize_sg_name(sg.get("GroupName", ""))
        bucket.setdefault(canon, []).append(
            f"{sg.get('GroupName')} ({sg.get('GroupId')})"
        )

    return {
        key: values
        for key, values in bucket.items()
        if len(values) > 1
    }


def build_target_index(target_groups: List[Dict[str, Any]]) -> Dict[str, List[Dict[str, Any]]]:
    """
    Index target SGs by:
    - exact GroupName
    - exact Name tag
    - canonical GroupName
    - canonical Name tag
    - CloudFormation logical-id / stack-name
    """
    index: Dict[str, List[Dict[str, Any]]] = {}

    def add(key: str, sg: Dict[str, Any]) -> None:
        if not key:
            return
        index.setdefault(key, []).append(sg)

    for sg in target_groups:
        group_name = sg.get("GroupName", "")
        name_tag = get_name_tag(sg)
        canon_group = normalize_sg_name(group_name)
        canon_tag = normalize_sg_name(name_tag or "")

        add(f"exact-group::{group_name}", sg)
        add(f"exact-group-lower::{group_name.lower()}", sg)

        if name_tag:
            add(f"exact-tag::{name_tag}", sg)
            add(f"exact-tag-lower::{name_tag.lower()}", sg)

        if canon_group:
            add(f"canon-group::{canon_group}", sg)

        if canon_tag:
            add(f"canon-tag::{canon_tag}", sg)

        logical_id = get_tag_value(sg, CFN_LOGICAL_ID_KEY)
        stack_name = get_tag_value(sg, CFN_STACK_NAME_KEY)

        if logical_id:
            add(f"cfn-logical::{logical_id.lower()}", sg)

        if logical_id and stack_name:
            add(f"cfn-stack-logical::{stack_name.lower()}::{logical_id.lower()}", sg)

    return index


def get_single_candidate(
    candidates: List[Dict[str, Any]],
) -> Tuple[Optional[Dict[str, Any]], bool, List[str]]:
    if not candidates:
        return None, False, []

    unique: Dict[str, Dict[str, Any]] = {}
    for sg in candidates:
        gid = sg.get("GroupId")
        if gid:
            unique[gid] = sg

    if len(unique) == 1:
        return next(iter(unique.values())), False, []

    display = [
        f"{sg.get('GroupName')} ({sg.get('GroupId')})"
        for sg in unique.values()
    ]

    return None, True, sorted(display)


def source_candidate_names(source_sg: Dict[str, Any]) -> List[str]:
    names: List[str] = []

    group_name = source_sg.get("GroupName")
    name_tag = get_name_tag(source_sg)

    for value in [group_name, name_tag]:
        if value and value not in names:
            names.append(value)

    return names


def match_source_sg(
    source_sg: Dict[str, Any],
    target_index: Dict[str, List[Dict[str, Any]]],
    target_groups: List[Dict[str, Any]],
) -> SgMatch:
    source_name = source_sg.get("GroupName", "")
    source_id = source_sg.get("GroupId", "")
    source_description = source_sg.get("Description", "")
    canonical_name = normalize_sg_name(source_name)

    candidate_names = source_candidate_names(source_sg)

    # 0. Directory suffix match.
    src_suffix = extract_directory_suffix(source_name)
    if src_suffix:
        matches = []
        for tgt in target_groups:
            tgt_suffix = extract_directory_suffix(tgt.get("GroupName", ""))
            if tgt_suffix == src_suffix:
                matches.append(tgt)

        target, ambiguous, candidates = get_single_candidate(matches)
        if target:
            return SgMatch(
                source_name=source_name,
                source_id=source_id,
                source_description=source_description,
                target_name=target.get("GroupName"),
                target_id=target.get("GroupId"),
                canonical_name=canonical_name,
                match_confidence="strict",
                matched_via="directory-suffix",
                strict_reason=f"matched by Directory SG suffix '{src_suffix}'",
            )

        if ambiguous:
            return SgMatch(
                source_name=source_name,
                source_id=source_id,
                source_description=source_description,
                target_name=None,
                target_id=None,
                canonical_name=canonical_name,
                match_confidence="ambiguous",
                matched_via="directory-suffix",
                strict_reason=f"ambiguous Directory SG suffix '{src_suffix}'",
                ambiguous=True,
                ambiguous_candidates=candidates,
            )

    # 1. Exact GroupName / Name tag match.
    for candidate in candidate_names:
        for key in [
            f"exact-group::{candidate}",
            f"exact-group-lower::{candidate.lower()}",
            f"exact-tag::{candidate}",
            f"exact-tag-lower::{candidate.lower()}",
        ]:
            target, ambiguous, candidates = get_single_candidate(target_index.get(key, []))

            if target:
                return SgMatch(
                    source_name=source_name,
                    source_id=source_id,
                    source_description=source_description,
                    target_name=target.get("GroupName"),
                    target_id=target.get("GroupId"),
                    canonical_name=canonical_name,
                    match_confidence="strict",
                    matched_via=key.split("::")[0],
                    strict_reason=f"matched by {key}",
                )

            if ambiguous:
                return SgMatch(
                    source_name=source_name,
                    source_id=source_id,
                    source_description=source_description,
                    target_name=None,
                    target_id=None,
                    canonical_name=canonical_name,
                    match_confidence="ambiguous",
                    matched_via=key.split("::")[0],
                    strict_reason=f"ambiguous match by {key}",
                    ambiguous=True,
                    ambiguous_candidates=candidates,
                )

    # 2. CloudFormation tags.
    source_logical_id = get_tag_value(source_sg, CFN_LOGICAL_ID_KEY)
    source_stack_name = get_tag_value(source_sg, CFN_STACK_NAME_KEY)

    cfn_keys: List[str] = []

    if source_logical_id and source_stack_name:
        cfn_keys.append(
            f"cfn-stack-logical::{source_stack_name.lower()}::{source_logical_id.lower()}"
        )

    if source_logical_id:
        cfn_keys.append(f"cfn-logical::{source_logical_id.lower()}")

    for key in cfn_keys:
        target, ambiguous, candidates = get_single_candidate(target_index.get(key, []))

        if target:
            return SgMatch(
                source_name=source_name,
                source_id=source_id,
                source_description=source_description,
                target_name=target.get("GroupName"),
                target_id=target.get("GroupId"),
                canonical_name=canonical_name,
                match_confidence="strict",
                matched_via=key.split("::")[0],
                strict_reason=f"matched by {key}",
            )

        if ambiguous:
            return SgMatch(
                source_name=source_name,
                source_id=source_id,
                source_description=source_description,
                target_name=None,
                target_id=None,
                canonical_name=canonical_name,
                match_confidence="ambiguous",
                matched_via=key.split("::")[0],
                strict_reason=f"ambiguous match by {key}",
                ambiguous=True,
                ambiguous_candidates=candidates,
            )

    # 3. Canonical fallback from GroupName / Name tag.
    for candidate in candidate_names:
        canon = normalize_sg_name(candidate)

        for key in [
            f"canon-group::{canon}",
            f"canon-tag::{canon}",
        ]:
            target, ambiguous, candidates = get_single_candidate(target_index.get(key, []))

            if target:
                return SgMatch(
                    source_name=source_name,
                    source_id=source_id,
                    source_description=source_description,
                    target_name=target.get("GroupName"),
                    target_id=target.get("GroupId"),
                    canonical_name=canon,
                    match_confidence="legacy",
                    matched_via=key.split("::")[0],
                    strict_reason="no exact match",
                    legacy_reason=f"matched by canonical key '{key}'",
                )

            if ambiguous:
                return SgMatch(
                    source_name=source_name,
                    source_id=source_id,
                    source_description=source_description,
                    target_name=None,
                    target_id=None,
                    canonical_name=canon,
                    match_confidence="ambiguous",
                    matched_via=key.split("::")[0],
                    strict_reason="no exact match",
                    legacy_reason=f"ambiguous canonical key '{key}'",
                    ambiguous=True,
                    ambiguous_candidates=candidates,
                )

    return SgMatch(
        source_name=source_name,
        source_id=source_id,
        source_description=source_description,
        target_name=None,
        target_id=None,
        canonical_name=canonical_name,
        match_confidence="none",
        matched_via="none",
        strict_reason="no matching target SG found",
    )


def match_security_groups(
    source_groups: List[Dict[str, Any]],
    target_groups: List[Dict[str, Any]],
) -> List[SgMatch]:
    target_index = build_target_index(target_groups)
    matches: List[SgMatch] = []

    for source_sg in source_groups:
        matches.append(
            match_source_sg(
                source_sg=source_sg,
                target_index=target_index,
                target_groups=target_groups,
            )
        )

    return matches


# --------------------------------------------------------------------
# DEPENDENCY / RULE REMAPPING
# --------------------------------------------------------------------

def build_source_id_to_match(matches: List[SgMatch]) -> Dict[str, SgMatch]:
    return {
        m.source_id: m
        for m in matches
        if m.source_id
    }


def build_source_id_to_target_id(matches: List[SgMatch]) -> Dict[str, str]:
    return {
        m.source_id: m.target_id
        for m in matches
        if m.source_id and m.target_id
    }


def remap_user_id_group_pairs(
    source_group_name: str,
    source_group_id: str,
    direction: str,
    rule: Dict[str, Any],
    sg_id_map: Dict[str, str],
    dependency_issues: List[RuleDependencyIssue],
) -> Dict[str, Any]:
    remapped_rule = json.loads(json.dumps(rule))

    pairs = remapped_rule.get("UserIdGroupPairs", [])
    if not pairs:
        return remapped_rule

    remapped_pairs = []

    for pair in pairs:
        pair_copy = dict(pair)
        referenced_source_group_id = pair.get("GroupId")
        referenced_group_name = pair.get("GroupName")

        if referenced_source_group_id in sg_id_map:
            pair_copy["GroupId"] = sg_id_map[referenced_source_group_id]
            pair_copy.pop("GroupName", None)
            pair_copy.pop("UserId", None)
            remapped_pairs.append(pair_copy)
        else:
            dependency_issues.append(
                RuleDependencyIssue(
                    source_group_name=source_group_name,
                    source_group_id=source_group_id,
                    direction=direction,
                    referenced_source_group_id=referenced_source_group_id,
                    referenced_group_name=referenced_group_name,
                    rule=rule,
                    reason=(
                        "Referenced SG could not be mapped to a target SG. "
                        "This rule is unsafe to apply until the dependency exists and is matched."
                    ),
                )
            )

    if remapped_pairs:
        remapped_rule["UserIdGroupPairs"] = remapped_pairs
    else:
        remapped_rule.pop("UserIdGroupPairs", None)

    return remapped_rule


def remap_rules_for_target(
    source_group_name: str,
    source_group_id: str,
    direction: str,
    rules: List[Dict[str, Any]],
    sg_id_map: Dict[str, str],
    dependency_issues: List[RuleDependencyIssue],
) -> List[Dict[str, Any]]:
    remapped: List[Dict[str, Any]] = []

    for rule in rules or []:
        remapped_rule = remap_user_id_group_pairs(
            source_group_name=source_group_name,
            source_group_id=source_group_id,
            direction=direction,
            rule=rule,
            sg_id_map=sg_id_map,
            dependency_issues=dependency_issues,
        )

        has_target = any(
            key in remapped_rule
            for key in [
                "IpRanges",
                "Ipv6Ranges",
                "PrefixListIds",
                "UserIdGroupPairs",
            ]
        )

        if remapped_rule.get("IpProtocol") == "-1" or has_target:
            remapped.append(remapped_rule)

    return remapped


def canonicalize_rule(rule: Dict[str, Any]) -> Dict[str, Any]:
    """
    Normalize a rule for comparison without changing its meaning.
    """
    normalized: Dict[str, Any] = {
        "IpProtocol": rule.get("IpProtocol")
    }

    if rule.get("FromPort") is not None:
        normalized["FromPort"] = rule.get("FromPort")

    if rule.get("ToPort") is not None:
        normalized["ToPort"] = rule.get("ToPort")

    def clean_list(items: List[Dict[str, Any]], id_key: str) -> List[Dict[str, Any]]:
        cleaned = []
        for item in items or []:
            x = {}
            if id_key in item:
                x[id_key] = item[id_key]
            if "Description" in item:
                x["Description"] = item["Description"]
            if x:
                cleaned.append(x)
        return sorted(cleaned, key=lambda v: json.dumps(v, sort_keys=True))

    ip_ranges = clean_list(rule.get("IpRanges", []), "CidrIp")
    ipv6_ranges = clean_list(rule.get("Ipv6Ranges", []), "CidrIpv6")
    prefix_lists = clean_list(rule.get("PrefixListIds", []), "PrefixListId")
    sg_pairs = clean_list(rule.get("UserIdGroupPairs", []), "GroupId")

    if ip_ranges:
        normalized["IpRanges"] = ip_ranges
    if ipv6_ranges:
        normalized["Ipv6Ranges"] = ipv6_ranges
    if prefix_lists:
        normalized["PrefixListIds"] = prefix_lists
    if sg_pairs:
        normalized["UserIdGroupPairs"] = sg_pairs

    return normalized


def canonicalize_rules(rules: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    out = []
    for rule in rules or []:
        canonical = canonicalize_rule(rule)
        has_target = any(
            key in canonical
            for key in [
                "IpRanges",
                "Ipv6Ranges",
                "PrefixListIds",
                "UserIdGroupPairs",
            ]
        )
        if canonical.get("IpProtocol") == "-1" or has_target:
            out.append(canonical)

    return sorted(out, key=lambda r: json.dumps(r, sort_keys=True))


def rule_key(rule: Dict[str, Any]) -> str:
    return json.dumps(rule, sort_keys=True, separators=(",", ":"))


def diff_rules(
    source_rules: List[Dict[str, Any]],
    target_rules: List[Dict[str, Any]],
) -> Tuple[List[Dict[str, Any]], List[Dict[str, Any]]]:
    source_map = {rule_key(r): r for r in canonicalize_rules(source_rules)}
    target_map = {rule_key(r): r for r in canonicalize_rules(target_rules)}

    missing = [
        source_map[key]
        for key in sorted(source_map.keys() - target_map.keys())
    ]

    extra = [
        target_map[key]
        for key in sorted(target_map.keys() - source_map.keys())
    ]

    return missing, extra


def diff_tags(
    source_tags: List[Dict[str, str]],
    target_tags: List[Dict[str, str]],
) -> Tuple[bool, int]:
    src = canonical_tags(source_tags)
    tgt = canonical_tags(target_tags)

    diff_keys = {
        key
        for key in src.keys() | tgt.keys()
        if src.get(key) != tgt.get(key)
    }

    return bool(diff_keys), len(diff_keys)
# --------------------------------------------------------------------
# PLAN BUILDER
# --------------------------------------------------------------------

def build_plan(
    source_groups: List[Dict[str, Any]],
    target_groups: List[Dict[str, Any]],
) -> SgPlan:
    matches = match_security_groups(source_groups, target_groups)

    target_by_id = {
        sg.get("GroupId"): sg
        for sg in target_groups
        if sg.get("GroupId")
    }

    source_by_id = {
        sg.get("GroupId"): sg
        for sg in source_groups
        if sg.get("GroupId")
    }

    sg_id_map = build_source_id_to_target_id(matches)

    drifts: List[SgDrift] = []
    missing: List[SgMatch] = []
    unresolved_dependencies: List[RuleDependencyIssue] = []

    for match in matches:
        if not match.target_id:
            missing.append(match)
            continue

        source_sg = source_by_id.get(match.source_id)
        target_sg = target_by_id.get(match.target_id)

        if not source_sg or not target_sg:
            continue

        remapped_source_ingress = remap_rules_for_target(
            source_group_name=match.source_name,
            source_group_id=match.source_id,
            direction="ingress",
            rules=source_sg.get("IpPermissions", []),
            sg_id_map=sg_id_map,
            dependency_issues=unresolved_dependencies,
        )

        remapped_source_egress = remap_rules_for_target(
            source_group_name=match.source_name,
            source_group_id=match.source_id,
            direction="egress",
            rules=source_sg.get("IpPermissionsEgress", []),
            sg_id_map=sg_id_map,
            dependency_issues=unresolved_dependencies,
        )

        target_ingress = target_sg.get("IpPermissions", [])
        target_egress = target_sg.get("IpPermissionsEgress", [])

        missing_ingress, extra_ingress = diff_rules(
            remapped_source_ingress,
            target_ingress,
        )

        missing_egress, extra_egress = diff_rules(
            remapped_source_egress,
            target_egress,
        )

        tag_drift, tag_diff_count = diff_tags(
            source_sg.get("Tags", []) or [],
            target_sg.get("Tags", []) or [],
        )

        description_drift = (
            (source_sg.get("Description") or "")
            != (target_sg.get("Description") or "")
        )

        if any(
            [
                missing_ingress,
                extra_ingress,
                missing_egress,
                extra_egress,
                tag_drift,
                description_drift,
            ]
        ):
            drifts.append(
                SgDrift(
                    group_name=match.source_name,
                    source_group_id=match.source_id,
                    target_group_id=match.target_id,
                    missing_ingress=missing_ingress,
                    extra_ingress=extra_ingress,
                    missing_egress=missing_egress,
                    extra_egress=extra_egress,
                    tag_drift=tag_drift,
                    tag_diff_count=tag_diff_count,
                    description_drift=description_drift,
                    match=match,
                )
            )

    duplicate_canonical_keys = build_duplicate_canonical_keys(target_groups)

    return SgPlan(
        matches=matches,
        drifts=drifts,
        missing=missing,
        unresolved_dependencies=unresolved_dependencies,
        duplicate_canonical_keys=duplicate_canonical_keys,
    )


