def print_summary(plan: SgPlan, max_preview_items: int = DEFAULT_MAX_PREVIEW_ITEMS) -> None:
    summary = plan_summary(plan)

    log("\n========== SECURITY GROUP SYNC SUMMARY ==========")
    log(f"Total source SGs          : {summary['total_source_sgs']}")
    log(f"In sync                   : {summary['in_sync']}")
    log(f"Strict matches            : {summary['strict_matches']}")
    log(f"Legacy matches            : {summary['legacy_matches']}")
    log(f"Missing in target         : {summary['missing_in_target']}")
    log(f"Drifted SGs               : {summary['drifted_sgs']}")
    log(f"Unresolved dependencies   : {summary['unresolved_dependencies']}")
    log(f"Duplicate canonical keys  : {summary['duplicate_canonical_keys']}")
    log("=================================================\n")

    if plan.missing:
        log("Missing SGs:")
        for match in plan.missing[:max_preview_items]:
            log(
                f" - {match.source_name} "
                f"(canonical={match.canonical_name}, reason={match.strict_reason})"
            )
        if len(plan.missing) > max_preview_items:
            log(f" - ... and {len(plan.missing) - max_preview_items} more")
        log("")

    legacy_matches = [
        match
        for match in plan.matches
        if match.target_id and match.match_confidence == "legacy"
    ]

    if legacy_matches:
        log("Legacy/canonical matches:")
        for match in legacy_matches[:max_preview_items]:
            log(
                f" - {match.source_name} -> {match.target_name} "
                f"({match.target_id}) via {match.matched_via}; "
                f"{match.legacy_reason or ''}"
            )
        if len(legacy_matches) > max_preview_items:
            log(f" - ... and {len(legacy_matches) - max_preview_items} more")
        log("")

    ambiguous_matches = [
        match
        for match in plan.matches
        if match.ambiguous
    ]

    if ambiguous_matches:
        log("Ambiguous matches:")
        for match in ambiguous_matches[:max_preview_items]:
            log(
                f" - {match.source_name} "
                f"(canonical={match.canonical_name}, via={match.matched_via})"
            )
            for candidate in match.ambiguous_candidates[:5]:
                log(f"     candidate: {candidate}")
        if len(ambiguous_matches) > max_preview_items:
            log(f" - ... and {len(ambiguous_matches) - max_preview_items} more")
        log("")

    if plan.drifts:
        log("Drifted SGs:")
        for drift in plan.drifts[:max_preview_items]:
            log(
                f" - {drift.group_name} -> {drift.target_group_id} "
                f"[match={drift.match.match_confidence}/{drift.match.matched_via}] "
                f"(+ing={len(drift.missing_ingress)}, "
                f"-ing={len(drift.extra_ingress)}, "
                f"+eg={len(drift.missing_egress)}, "
                f"-eg={len(drift.extra_egress)}, "
                f"tag_drift={drift.tag_drift}, "
                f"description_drift={drift.description_drift})"
            )
        if len(plan.drifts) > max_preview_items:
            log(f" - ... and {len(plan.drifts) - max_preview_items} more")
        log("")

    if plan.unresolved_dependencies:
        log("Unresolved SG dependencies:")
        for issue in plan.unresolved_dependencies[:max_preview_items]:
            log(
                f" - {issue.source_group_name} [{issue.direction}] "
                f"references {issue.referenced_source_group_id or issue.referenced_group_name}; "
                f"{issue.reason}"
            )
        if len(plan.unresolved_dependencies) > max_preview_items:
            log(f" - ... and {len(plan.unresolved_dependencies) - max_preview_items} more")
        log("")

    if plan.duplicate_canonical_keys:
        log("Duplicate canonical keys in target:")
        shown = 0
        for key, values in plan.duplicate_canonical_keys.items():
            log(f" - {key}:")
            for value in values[:5]:
                log(f"     {value}")
            shown += 1
            if shown >= max_preview_items:
                remaining = len(plan.duplicate_canonical_keys) - shown
                if remaining > 0:
                    log(f" - ... and {remaining} more duplicate canonical key group(s)")
                break
        log("")


def print_final_cli_summary(
    plan: SgPlan,
    report_path: str,
    mode: str,
) -> None:
    summary = plan_summary(plan)

    log("\n" + "=" * 72)
    log("SECURITY GROUP SYNC RUN FINAL SUMMARY")
    log("=" * 72)
    log(f"Mode                       : {mode}")
    log(f"Total source SGs           : {summary['total_source_sgs']}")
    log(f"In sync                    : {summary['in_sync']}")
    log(f"Strict matches             : {summary['strict_matches']}")
    log(f"Legacy matches             : {summary['legacy_matches']}")
    log(f"Missing in target          : {summary['missing_in_target']}")
    log(f"Drifted SGs                : {summary['drifted_sgs']}")
    log(f"Unresolved dependencies    : {summary['unresolved_dependencies']}")
    log(f"Duplicate canonical keys   : {summary['duplicate_canonical_keys']}")
    log(f"Report written to          : {report_path}")

    if summary["missing_in_target"] == 0 and summary["drifted_sgs"] == 0 and summary["unresolved_dependencies"] == 0:
        log("\nResult: All matched security groups are in sync.")

    if summary["legacy_matches"] > 0:
        log("\nNote: Legacy/canonical matches were detected.")
        log("Review the report carefully before applying changes with --allow-legacy.")

    if summary["unresolved_dependencies"] > 0:
        log("\nNote: Unresolved SG dependencies were detected.")
        log("Rules referencing unmapped SGs are unsafe to apply until dependencies are matched.")

    if summary["duplicate_canonical_keys"] > 0:
        log("\nNote: Duplicate canonical keys were detected.")
        log("Exact matches are still safe, but canonical fallback may be ambiguous.")

    log("=" * 72 + "\n")


# --------------------------------------------------------------------
# MAIN
# --------------------------------------------------------------------

def mode_name(args: Args) -> str:
    if args.dry_run:
        return "dry-run"
    if args.report_only:
        return "report-only"
    if args.yes:
        return "yes"
    return "unknown"


def main() -> int:
    args = parse_args()
    mode = mode_name(args)

    log(f"[INFO] Loading source SGs from JSON: {args.json_path}")
    source_groups = load_source_sgs_from_json(args.json_path)
    log(f"[INFO] Loaded {len(source_groups)} non-default source SGs")

    log(
        f"[INFO] Connecting to target AWS "
        f"(profile={args.target_profile}, region={args.target_region})"
    )
    ec2 = get_ec2_client(args.target_profile, args.target_region)

    log(f"[INFO] Fetching target SGs from VPC {args.target_vpc_id}")
    target_groups = get_sgs_for_vpc(ec2, args.target_vpc_id)
    log(f"[INFO] Loaded {len(target_groups)} non-default target SGs")

    log("[INFO] Building initial plan...")
    initial_plan = build_plan(source_groups, target_groups)

    print_summary(initial_plan, args.max_preview_items)

    if args.dry_run or args.report_only:
        write_report(args.report_path, initial_plan, mode)
        print_final_cli_summary(initial_plan, args.report_path, mode)
        return 0

    log("\n[APPLY] Applying remediation...")
    final_plan = apply_plan(
        ec2=ec2,
        source_groups=source_groups,
        target_vpc_id=args.target_vpc_id,
        plan=initial_plan,
        args=args,
    )

    write_report(args.report_path, final_plan, mode)
    print_final_cli_summary(final_plan, args.report_path, mode)

    log("[APPLY] Done.")
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        eprint("[ABORTED] Interrupted by user.")
        sys.exit(130)
    except Exception as exc:
        eprint(f"[FATAL] {exc}")
        sys.exit(1)
