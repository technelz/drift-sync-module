#!/usr/bin/env python3
"""
================================================================================
Enterprise AWS Security Group Sync Tool
================================================================================

Purpose:
- Read source/Prod security groups from an exported JSON file.
- Read target/DR security groups live from AWS.
- Match source SGs to target SGs safely.
- Detect drift in rules, tags, descriptions, and dependencies.
- Create missing SG shells first.
- Remap SG-to-SG references from source SG IDs to target SG IDs.
- Apply missing rules only after dependencies are resolved.
- Optionally revoke extra rules.
- Continue safely on duplicate SG creation.
- Produce a JSON report and clear CLI summary.

Recommended workflow:
1. Run --dry-run first.
2. Review report.
3. Run --yes only after review.

Important:
- Default SG is skipped.
- Source SG IDs are never assumed valid in target.
- SG-to-SG references are remapped before rule application.
- Unresolved dependencies block --yes by default.
================================================================================
"""

import sys
import json
import argparse
import re
import os
import time
from datetime import datetime
from typing import Any, Dict, List, Optional, Tuple, Set
from dataclasses import dataclass, field, asdict

import boto3
from botocore.exceptions import ClientError


