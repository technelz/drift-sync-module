# --------------------------------------------------------------------

def log(msg: str) -> None:
    print(msg, file=sys.stdout, flush=True)


def eprint(msg: str) -> None:
    print(msg, file=sys.stderr, flush=True)


# --------------------------------------------------------------------
# CONSTANTS
# --------------------------------------------------------------------

DEFAULT_REPORT_DIR = "sg_reports"

SYSTEM_TAG_KEYS_TO_IGNORE = {
    "aws:cloudformation:logical-id",
    "aws:cloudformation:stack-id",
    "aws:cloudformation:stack-name",
}

CFN_LOGICAL_ID_KEY = "aws:cloudformation:logical-id"
CFN_STACK_NAME_KEY = "aws:cloudformation:stack-name"

DEFAULT_MAX_PREVIEW_ITEMS = 25


# --------------------------------------------------------------------
# DATA MODELS
# --------------------------------------------------------------------

@dataclass
class Args:
    json_path: str
    target_vpc_id: str
    target_profile: Optional[str]
    target_region: Optional[str]
    dry_run: bool
    report_only: bool
    yes: bool
    allow_legacy: bool
    allow_unresolved_dependencies: bool
    revoke_extra_rules: bool
    no_create_missing: bool
    no_sync_tags: bool
    report_path: str
    max_preview_items: int


@dataclass
class SgMatch:
    source_name: str
    source_id: str
    source_description: str
    target_name: Optional[str]
    target_id: Optional[str]
    canonical_name: str
    match_confidence: str
    matched_via: str
    strict_reason: str
    legacy_reason: Optional[str] = None
    ambiguous: bool = False
    ambiguous_candidates: List[str] = field(default_factory=list)


@dataclass
class RuleDependencyIssue:
    source_group_name: str
    source_group_id: str
    direction: str
    referenced_source_group_id: Optional[str]
    referenced_group_name: Optional[str]
    rule: Dict[str, Any]
    reason: str


@dataclass
class SgDrift:
    group_name: str
    source_group_id: str
    target_group_id: str
    missing_ingress: List[Dict[str, Any]]
    extra_ingress: List[Dict[str, Any]]
    missing_egress: List[Dict[str, Any]]
    extra_egress: List[Dict[str, Any]]
    tag_drift: bool
    tag_diff_count: int
    description_drift: bool
    match: SgMatch


@dataclass
class SgPlan:
    matches: List[SgMatch]
    drifts: List[SgDrift]
    missing: List[SgMatch]
    unresolved_dependencies: List[RuleDependencyIssue]
    duplicate_canonical_keys: Dict[str, List[str]] = field(default_factory=dict)

    @property
    def total(self) -> int:
        return len(self.matches)

    @property
    def strict_matches(self) -> int:
        return len([m for m in self.matches if m.target_id and m.match_confidence == "strict"])

    @property
    def legacy_matches(self) -> int:
        return len([m for m in self.matches if m.target_id and m.match_confidence == "legacy"])

    @property
    def missing_count(self) -> int:
        return len(self.missing)

    @property
    def drift_count(self) -> int:
        return len(self.drifts)

    @property
    def unresolved_dependency_count(self) -> int:
        return len(self.unresolved_dependencies)

    @property
    def in_sync_count(self) -> int:
        return max(self.total - self.missing_count - self.drift_count, 0)


# --------------------------------------------------------------------
# CLI
# --------------------------------------------------------------------

def parse_args() -> Args:
    parser = argparse.ArgumentParser(
        description="Enterprise AWS Security Group sync from source JSON export to target VPC."
    )

    parser.add_argument(
        "--json-path",
        required=True,
        help="Path to source SG JSON export from aws ec2 describe-security-groups.",
    )

    parser.add_argument(
        "--target-vpc-id",
        required=True,
        help="Target VPC ID where SGs will be reconciled or created.",
    )

    parser.add_argument(
        "--target-profile",
        default=None,
        help="AWS CLI profile for the target account.",
    )

    parser.add_argument(
        "--target-region",
        default=None,
        help="AWS region for target account.",
    )

    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Audit only. No changes are applied.",
    )

    parser.add_argument(
        "--report-only",
        action="store_true",
        help="Write report and exit. No changes are applied.",
    )

    parser.add_argument(
        "--yes",
        action="store_true",
        help="Apply remediation.",
    )

    parser.add_argument(
        "--allow-legacy",
        action="store_true",
        help="Allow remediation for canonical/legacy matches.",
    )

    parser.add_argument(
        "--allow-unresolved-dependencies",
        action="store_true",
        help="Allow --yes to continue even if some SG references cannot be remapped. Unsafe; not recommended.",
    )

    parser.add_argument(
        "--revoke-extra-rules",
        action="store_true",
        help="Remove rules in target that are not present in source.",
    )

    parser.add_argument(
        "--no-create-missing",
        action="store_true",
        help="Do not create missing target SG shells.",
    )

    parser.add_argument(
        "--no-sync-tags",
        action="store_true",
        help="Do not sync tags.",
    )

    parser.add_argument(
        "--report-path",
        default=None,
        help="Custom JSON report path.",
    )

    parser.add_argument(
        "--max-preview-items",
        type=int,
        default=DEFAULT_MAX_PREVIEW_ITEMS,
        help="Maximum missing/drift/dependency items to show in CLI summary.",
    )

    ns = parser.parse_args()

    selected_modes = sum([bool(ns.dry_run), bool(ns.report_only), bool(ns.yes)])
    if selected_modes != 1:
        raise ValueError("Choose exactly one mode: --dry-run, --report-only, or --yes.")

    if ns.report_path:
        report_path = ns.report_path
    else:
        ts = datetime.utcnow().strftime("%Y-%m-%d_%H-%M-%S")
        report_path = os.path.join(DEFAULT_REPORT_DIR, f"sg_sync_report_{ts}.json")

    return Args(
        json_path=ns.json_path,
        target_vpc_id=ns.target_vpc_id,
        target_profile=ns.target_profile,
        target_region=ns.target_region,
        dry_run=ns.dry_run,
        report_only=ns.report_only,
        yes=ns.yes,
        allow_legacy=ns.allow_legacy,
        allow_unresolved_dependencies=ns.allow_unresolved_dependencies,
        revoke_extra_rules=ns.revoke_extra_rules,
        no_create_missing=ns.no_create_missing,
        no_sync_tags=ns.no_sync_tags,
        report_path=report_path,
        max_preview_items=ns.max_preview_items,
    )


