def find_existing_sg_by_group_name(
    ec2,
    target_vpc_id: str,
    group_name: str,
) -> Optional[Dict[str, Any]]:
    response = ec2.describe_security_groups(
        Filters=[
            {"Name": "vpc-id", "Values": [target_vpc_id]},
            {"Name": "group-name", "Values": [group_name]},
        ]
    )

    groups = response.get("SecurityGroups", [])

    if groups:
        return groups[0]

    return None


def create_missing_sg_shell(
    ec2,
    target_vpc_id: str,
    source_sg: Dict[str, Any],
) -> str:
    """
    Ensure the target SG shell exists.

    Rules are intentionally NOT added here.
    All SG shells must exist first so SG-to-SG rule references can be remapped.
    """
    source_name = source_sg.get("GroupName", "")
    create_name = derive_new_sg_name(source_name)
    description = source_sg.get("Description") or f"Cloned from {source_name}"

    log(f"[CREATE-SG] Ensuring SG '{create_name}' exists in VPC {target_vpc_id}")

    existing = find_existing_sg_by_group_name(
        ec2=ec2,
        target_vpc_id=target_vpc_id,
        group_name=create_name,
    )

    if existing:
        existing_id = existing.get("GroupId", "")
        log(f"[CREATE-SG] SG '{create_name}' already exists. Reusing {existing_id}")
        return existing_id

    try:
        response = ec2.create_security_group(
            GroupName=create_name,
            Description=description[:255],
            VpcId=target_vpc_id,
        )

        new_id = response["GroupId"]
        log(f"[CREATE-SG] Created SG '{create_name}' as {new_id}")

    except ClientError as exc:
        code = exc.response.get("Error", {}).get("Code", "")

        if code == "InvalidGroup.Duplicate":
            existing = find_existing_sg_by_group_name(
                ec2=ec2,
                target_vpc_id=target_vpc_id,
                group_name=create_name,
            )

            if existing:
                existing_id = existing.get("GroupId", "")
                log(f"[CREATE-SG] Duplicate detected. Reusing {existing_id}")
                return existing_id

            log(
                f"[CREATE-SG] Duplicate detected for '{create_name}', "
                "but lookup did not return a group. Skipping creation."
            )
            return ""

        raise

    tags = clean_tags_for_copy(source_sg.get("Tags", []) or [])

    if tags:
        try:
            ec2.create_tags(Resources=[new_id], Tags=tags)
            log(f"[TAGS] Applied {len(tags)} tags to {new_id}")
        except ClientError as exc:
            log(f"[WARN] Failed to apply tags to {new_id}: {exc}")

    return new_id


def create_missing_sg_shells(
    ec2,
    plan: SgPlan,
    source_groups: List[Dict[str, Any]],
    target_vpc_id: str,
) -> None:
    if not plan.missing:
        return

    source_by_id = {
        sg.get("GroupId"): sg
        for sg in source_groups
        if sg.get("GroupId")
    }

    log("\n[APPLY] Creating missing SG shells...")

    for match in plan.missing:
        source_sg = source_by_id.get(match.source_id)

        if not source_sg:
            log(f"[WARN] Source SG object not found for {match.source_name}; skipping create.")
            continue

        try:
            ensured_id = create_missing_sg_shell(
                ec2=ec2,
                target_vpc_id=target_vpc_id,
                source_sg=source_sg,
            )

            if ensured_id:
                log(f"[CREATE-SG] Ensured {ensured_id} for source {match.source_name}")
            else:
                log(f"[CREATE-SG] Skipped create for {match.source_name}; no SG ID returned.")

        except ClientError as exc:
            code = exc.response.get("Error", {}).get("Code", "")

            if code == "InvalidGroup.Duplicate":
                log(f"[CREATE-SG] Duplicate detected for {match.source_name}. Continuing.")
                continue

            raise


