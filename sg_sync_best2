# --------------------------------------------------------------------
# SAFETY CHECKS
# --------------------------------------------------------------------
def should_block_apply(plan: SgPlan, args: Args) -> Tuple[bool, List[str]]:
    reasons: List[str] = []
    fatal: List[str] = []

    legacy_matches = [...]
    ambiguous_matches = [...]

    # Ambiguous matches are always fatal
    if ambiguous_matches:
        fatal.append(
            f"{len(ambiguous_matches)} ambiguous matches detected. "
            "Resolve ambiguity before applying."
        )

    # Legacy matches are confirmable
    if legacy_matches and not args.allow_legacy:
        reasons.append(...)

    # Unresolved dependencies are confirmable
    if plan.unresolved_dependencies and not args.allow_unresolved_dependencies:
        reasons.append(...)

    # If user explicitly approved, only block on fatal errors
    if args.yes:
        if fatal:
            return True, fatal
        return False, []

    # Normal mode: block on everything
    all_reasons = fatal + reasons
    return (len(all_reasons) > 0, all_reasons)

    # -------------------------
    # CLASSIFY REASONS
    # -------------------------

    # Ambiguous matches are always fatal
    if ambiguous_matches:
        fatal.append(
            f"{len(ambiguous_matches)} ambiguous matches detected. "
            "Resolve ambiguity before applying."
        )

    # Legacy matches are confirmable
    if legacy_matches and not args.allow_legacy:
        reasons.append(
            f"{len(legacy_matches)} legacy/canonical matches detected. "
            "Use --allow-legacy only after reviewing the report."
        )

    # Unresolved dependencies are confirmable
    if plan.unresolved_dependencies and not args.allow_unresolved_dependencies:
        reasons.append(
            f"{len(plan.unresolved_dependencies)} unresolved SG dependencies detected. "
            "Fix matching/dependencies before applying."
        )

    # -------------------------
    # DECISION LOGIC
    # -------------------------

    # If user explicitly approved, only block on fatal errors
    if args.yes:
        if fatal:
            return True, fatal
        return False, []

    # Normal mode: block on everything
    all_reasons = fatal + reasons
    return (len(all_reasons) > 0, all_reasons)

# --------------------------------------------------------------------
# APPLY PLAN
# --------------------------------------------------------------------

def apply_plan(
    ec2,
    source_groups: List[Dict[str, Any]],
    target_vpc_id: str,
    plan: SgPlan,
    args: Args,
) -> SgPlan:
    block, reasons = should_block_apply(plan, args)

    if block:
        log("\n[SAFETY BLOCK] Remediation halted.")
        for reason in reasons:
            log(f" - {reason}")
        log("Review the report, fix issues, then rerun.")
        return plan

    if not args.no_create_missing:
        create_missing_sg_shells(
            ec2=ec2,
            plan=plan,
            source_groups=source_groups,
            target_vpc_id=target_vpc_id,
        )
    else:
        log("[SKIP-CREATE] --no-create-missing was provided.")

    log("\n[APPLY] Refreshing target inventory after SG shell ensure...")
    refreshed_targets = get_sgs_for_vpc(ec2, target_vpc_id)
    refreshed_plan = build_plan(source_groups, refreshed_targets)

    block_after_refresh, reasons_after_refresh = should_block_apply(
        refreshed_plan,
        args,
    )

    if block_after_refresh:
        log("\n[SAFETY BLOCK] Remediation halted after refresh.")
        for reason in reasons_after_refresh:
            log(f" - {reason}")
        log("No rules were applied.")
        return refreshed_plan

    log("\n[APPLY] Reconciling drift...")

    source_by_id = {
        sg.get("GroupId"): sg
        for sg in source_groups
        if sg.get("GroupId")
    }

    for drift in refreshed_plan.drifts:
        source_sg = source_by_id.get(drift.source_group_id)

        if not source_sg:
            log(f"[WARN] Source SG not found for drift item {drift.group_name}; skipping.")
            continue

        if not args.no_sync_tags and drift.tag_drift:
            sync_tags_to_target(
                ec2=ec2,
                target_group_id=drift.target_group_id,
                source_tags=source_sg.get("Tags", []) or [],
            )

        if drift.missing_ingress:
            safe_authorize_ingress(
                ec2=ec2,
                group_id=drift.target_group_id,
                rules=drift.missing_ingress,
            )

        if drift.missing_egress:
            safe_authorize_egress(
                ec2=ec2,
                group_id=drift.target_group_id,
                rules=drift.missing_egress,
            )

        if args.revoke_extra_rules:
            if drift.extra_ingress:
                safe_revoke_ingress(
                    ec2=ec2,
                    group_id=drift.target_group_id,
                    rules=drift.extra_ingress,
                )

            if drift.extra_egress:
                safe_revoke_egress(
                    ec2=ec2,
                    group_id=drift.target_group_id,
                    rules=drift.extra_egress,
                )
        else:
            if drift.extra_ingress or drift.extra_egress:
                log(
                    f"[SKIP-REVOKE] Extra rules left untouched for {drift.group_name}. "
                    "Use --revoke-extra-rules to remove them."
                )

    log("[APPLY] Remediation pass completed.")

    final_targets = get_sgs_for_vpc(ec2, target_vpc_id)
    final_plan = build_plan(source_groups, final_targets)

    return final_plan
