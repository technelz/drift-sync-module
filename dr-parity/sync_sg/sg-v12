def write_json_report(results: List[SgAuditResult], json_report_path: str) -> None:

    summary = {

        "total": len(results),

        "in_sync": sum(1 for r in results if r.in_sync),

        "out_of_sync": sum(1 for r in results if not r.in_sync),

        "missing": [r.group_name for r in results if not r.exists_in_target],

        "drift": [

            {

                "group_name": r.group_name,

                "fields": r.drift_fields,

            }

            for r in results

            if r.exists_in_target and not r.in_sync

        ],

    }

    full_report = {

        "summary": summary,

        "security_groups": [asdict(r) | {"in_sync": r.in_sync} for r in results],

    }

    with open(json_report_path, "w", encoding="utf-8") as jf:

        json.dump(full_report, jf, indent=2)

    print(f"[INFO] JSON report written to {json_report_path}")

