# Reconciliation

# --------------------------------------------------------------------

def ensure_all_target_sgs_exist(

    source_groups: List[Dict[str, Any]],

    ec2_tgt,

    tgt_map: Dict[str, Dict[str, Any]],

    src_acct: Optional[str],

    tgt_acct: str,

    args: Args,

) -> None:

    """

    Phase 1: serial SG shell creation so SG references resolve before threading.

    """

    for sg in source_groups:

        raw_name = sg["GroupName"]

        canon_name = normalize_sg_name(raw_name, src_acct, tgt_acct)

        if canon_name not in tgt_map and not args.report_only:

            gid = create_or_get_sg(ec2_tgt, sg, args.target_vpc_id, src_acct, tgt_acct, args.dry_run)

            if not args.dry_run:

                tgt_map[canon_name] = retry_aws(

                    lambda gid=gid: ec2_tgt.describe_security_groups(GroupIds=[gid])

                )["SecurityGroups"][0]

def reconcile_one_sg(

    sg: Dict[str, Any],

    ec2_tgt,

    tgt_map: Dict[str, Dict[str, Any]],

    src_id_to_name: Dict[str, str],

    tgt_name_to_id: Dict[str, str],

    src_acct: Optional[str],

    tgt_acct: str,

    args: Args,

) -> Tuple[SgAuditResult, Optional[str]]:

    raw_name = sg["GroupName"]

    canon_name = normalize_sg_name(raw_name, src_acct, tgt_acct)

    tgt_sg = tgt_map.get(canon_name)

    src_ing, src_ing_unresolved = normalize_permissions(

        sg.get("IpPermissions", []),

        src_id_to_name,

        tgt_name_to_id,

        src_acct,

        tgt_acct,

    )

    src_eg, src_eg_unresolved = normalize_permissions(

        sg.get("IpPermissionsEgress", []),

        src_id_to_name,

        tgt_name_to_id,

        src_acct,

        tgt_acct,

    )

    src_tags = canonical_tags(sg.get("Tags"))

    src_desc = sg.get("Description", "")

    if tgt_sg:

        tgt_ing, _ = normalize_permissions(

            tgt_sg.get("IpPermissions", []),

            src_id_to_name,

            tgt_name_to_id,

            src_acct,

            tgt_acct,

        )

        tgt_eg, _ = normalize_permissions(

            tgt_sg.get("IpPermissionsEgress", []),

            src_id_to_name,

            tgt_name_to_id,

            src_acct,

            tgt_acct,

        )

        tgt_tags = canonical_tags(tgt_sg.get("Tags"))

        tgt_desc = tgt_sg.get("Description", "")

    else:

        tgt_ing, tgt_eg, tgt_tags, tgt_desc = [], [], [], ""

    audit = audit_sg(

        sg, src_desc, src_tags, src_ing, src_eg,

        tgt_sg, tgt_desc, tgt_tags, tgt_ing, tgt_eg,

    )

    if src_ing_unresolved:

        audit.notes.extend(src_ing_unresolved)

    if src_eg_unresolved:

        audit.notes.extend(src_eg_unresolved)

    if args.report_only or not tgt_sg:

        return audit, None

    gid = tgt_sg["GroupId"]

    changed = False

    # group description itself is effectively immutable post-create for SG object;

    # keep this as audit-only drift signal.

    if src_desc != tgt_desc:

        audit.notes.append("Group description drift detected; existing SG description is not mutated by this tool.")

    if src_tags != tgt_tags:

        sync_tags(ec2_tgt, gid, src_tags, tgt_tags, args.dry_run)

        changed = True

    add_ing, remove_ing = diff_permissions(src_ing, tgt_ing)

    if add_ing or remove_ing:

        log(f"[SYNC] Ingress differs for {canon_name}")

        revoke_permissions(ec2_tgt, gid, remove_ing, "ingress", args.dry_run)

        authorize_permissions(ec2_tgt, gid, add_ing, "ingress", args.dry_run)

        changed = True

    add_eg, remove_eg = diff_permissions(src_eg, tgt_eg)

    if add_eg or remove_eg:

        log(f"[SYNC] Egress differs for {canon_name}")

        revoke_permissions(ec2_tgt, gid, remove_eg, "egress", args.dry_run)

        authorize_permissions(ec2_tgt, gid, add_eg, "egress", args.dry_run)

        changed = True

    return audit, (gid if changed else None)

def parallel_reconcile(

    source_groups: List[Dict[str, Any]],

    ec2_tgt,

    tgt_map: Dict[str, Dict[str, Any]],

    src_id_to_name: Dict[str, str],

    tgt_name_to_id: Dict[str, str],

    src_acct: Optional[str],

    tgt_acct: str,

    args: Args,

) -> List[SgAuditResult]:

    audit_results: List[SgAuditResult] = []

    changed_group_ids: List[str] = []

    snapshots: Dict[str, SgSnapshot] = {}

    # Snapshot all existing target SGs before mutation.

    for _, sg in tgt_map.items():

        snapshots[sg["GroupId"]] = snapshot_target_sg(

            sg, src_id_to_name, tgt_name_to_id, src_acct, tgt_acct

        )

    first_error: Optional[Exception] = None

    futures = []

    with ThreadPoolExecutor(max_workers=args.workers) as executor:

        for sg in source_groups:

            futures.append(

                executor.submit(

                    reconcile_one_sg,

                    sg,

                    ec2_tgt,

                    tgt_map,

                    src_id_to_name,

                    tgt_name_to_id,

                    src_acct,

                    tgt_acct,

                    args,

                )

            )

        for future in as_completed(futures):

            try:

                audit, changed_gid = future.result()

                audit_results.append(audit)

                if changed_gid:

                    changed_group_ids.append(changed_gid)

            except Exception as exc:

                first_error = exc

                eprint(f"[ERROR] Worker failed: {exc}")

                break

    if first_error:

        if args.rollback_on_error and not args.dry_run and not args.report_only:

            rollback_changes(ec2_tgt, snapshots, changed_group_ids, dry_run=False)

        raise RuntimeError(f"Parallel sync failed: {first_error}") from first_error

    # Make output deterministic

    audit_results.sort(key=lambda r: r.group_name)

    return audit_results

