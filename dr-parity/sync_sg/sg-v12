def normalize_args(p: argparse.ArgumentParser, ns: argparse.Namespace) -> Args:

    source_profile = ns.source_profile or ns.prod_profile

    source_region = ns.source_region or ns.prod_region

    source_vpc_id = ns.source_vpc_id or ns.prod_vpc_id

    target_profile = ns.target_profile or ns.dr_profile

    target_region = ns.target_region or ns.dr_region

    target_vpc_id = ns.target_vpc_id or ns.dr_vpc_id

    if not target_profile or not target_region or not target_vpc_id:

        p.error("Target/DR values are required.")

    if not ns.json_path:

        missing = []

        if not source_profile:

            missing.append("source/prod profile")

        if not source_region:

            missing.append("source/prod region")

        if not source_vpc_id:

            missing.append("source/prod vpc id")

        if missing:

            p.error(f"Missing: {', '.join(missing)}")

    workers = max(1, int(ns.workers))

    rollback_on_error = not ns.no_rollback

    return Args(

        json_path=ns.json_path,

        source_profile=source_profile,

        source_region=source_region,

        source_vpc_id=source_vpc_id,

        target_profile=target_profile,

        target_region=target_region,

        target_vpc_id=target_vpc_id,

        dry_run=ns.dry_run,

        report_only=ns.report_only,

        yes=ns.yes,

        name_preview=ns.name_preview,

        workers=workers,

        rollback_on_error=rollback_on_error,

        report_path=ns.report_path,

    )

def parse_args() -> Args:

    p = argparse.ArgumentParser(description="Sync AWS Security Groups")

    src = p.add_argument_group("source")

    src.add_argument("--json-path")

    src.add_argument("--source-profile")

    src.add_argument("--source-region")

    src.add_argument("--source-vpc-id")

    prod = p.add_argument_group("prod aliases")

    prod.add_argument("--prod-profile")

    prod.add_argument("--prod-region")

    prod.add_argument("--prod-vpc-id")

    tgt = p.add_argument_group("target")

    tgt.add_argument("--target-profile")

    tgt.add_argument("--target-region")

    tgt.add_argument("--target-vpc-id")

    dr = p.add_argument_group("dr aliases")

    dr.add_argument("--dr-profile")

    dr.add_argument("--dr-region")

    dr.add_argument("--dr-vpc-id")

    p.add_argument("--dry-run", action="store_true", help="Show what would change.")

    p.add_argument("--report-only", action="store_true", help="Audit only, do not modify.")

    p.add_argument("--yes", action="store_true", help="Skip interactive confirmation.")

    p.add_argument("--name-preview", action="store_true", help="Preview source->target SG names and exit.")

    p.add_argument("--workers", type=int, default=4, help="Worker count for parallel reconciliation.")

    p.add_argument("--no-rollback", action="store_true", help="Disable automatic rollback on failure.")

    p.add_argument("--report-path", default=DEFAULT_REPORT_PATH, help="Path to JSON audit report.")

    ns = p.parse_args()

    return normalize_args(p, ns)

# --------------------------------------------------------------------

# Tag Helpers

# --------------------------------------------------------------------

def canonical_tags(tags: Optional[List[Dict[str, str]]]) -> List[Tuple[str, str]]:

    out: List[Tuple[str, str]] = []

    for t in tags or []:

        key = t.get("Key", "")

        val = t.get("Value", "")

        if key and key not in SYSTEM_TAG_KEYS_TO_IGNORE:

            out.append((key, val))

    return sorted(out)

def tags_to_aws_payload(tags: List[Tuple[str, str]]) -> List[Dict[str, str]]:

    return [{"Key": k, "Value": v} for k, v in tags]

