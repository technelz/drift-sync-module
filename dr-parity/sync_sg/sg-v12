def create_or_get_sg(

    ec2,

    source_sg: Dict[str, Any],

    vpc_id: str,

    src_acct: Optional[str],

    tgt_acct: str,

    dry_run: bool,

) -> str:

    raw = source_sg["GroupName"]

    name = normalize_sg_name(raw, src_acct, tgt_acct)

    existing = retry_aws(

        lambda: ec2.describe_security_groups(

            Filters=[

                {"Name": "vpc-id", "Values": [vpc_id]},

                {"Name": "group-name", "Values": [name]},

            ]

        )

    ).get("SecurityGroups", [])

    if existing:

        return existing[0]["GroupId"]

    desc = source_sg.get("Description", f"Synced SG: {name}")

    if dry_run:

        log(f"[DRY-RUN] Would create SG: {name}")

        return f"dryrun:{name}"

    try:

        resp = retry_aws(

            lambda: ec2.create_security_group(

                GroupName=name,

                Description=desc[:255] if desc else name[:255],

                VpcId=vpc_id,

            )

        )

        gid = resp["GroupId"]

        log(f"[CREATE] SG created: {name} ({gid})")

        return gid

    except ClientError as exc:

        code = exc.response.get("Error", {}).get("Code", "")

        if code == "InvalidGroup.Duplicate":

            # race-safe fallback

            existing = retry_aws(

                lambda: ec2.describe_security_groups(

                    Filters=[

                        {"Name": "vpc-id", "Values": [vpc_id]},

                        {"Name": "group-name", "Values": [name]},

                    ]

                )

            ).get("SecurityGroups", [])

            if existing:

                return existing[0]["GroupId"]

        raise

def sync_tags(ec2, gid: str, desired: List[Tuple[str, str]], current: List[Tuple[str, str]], dry_run: bool) -> None:

    if desired == current:

        return

    log(f"[SYNC] Tags differ for {gid}")

    if dry_run:

        log(f"[DRY-RUN] Current tags: {current}")

        log(f"[DRY-RUN] Desired tags: {desired}")

        return

    if desired:

        retry_aws(lambda: ec2.create_tags(Resources=[gid], Tags=tags_to_aws_payload(desired)))

    current_keys = {k for k, _ in current}

    desired_keys = {k for k, _ in desired}

    to_remove = current_keys - desired_keys

    if to_remove:

        retry_aws(

            lambda: ec2.delete_tags(

                Resources=[gid],

                Tags=[{"Key": k} for k in sorted(to_remove)],

            )

        )

def revoke_permissions(ec2, gid: str, perms: List[Dict[str, Any]], direction: str, dry_run: bool) -> None:

    if not perms:

        return

    if dry_run:

        log(f"[DRY-RUN] Would revoke {direction} on {gid}: {json.dumps(perms, default=str)}")

        return

    try:

        if direction == "ingress":

            retry_aws(lambda: ec2.revoke_security_group_ingress(GroupId=gid, IpPermissions=perms))

        else:

            retry_aws(lambda: ec2.revoke_security_group_egress(GroupId=gid, IpPermissions=perms))

    except ClientError as exc:

        raise RuntimeError(f"Failed revoking {direction} on {gid}: {exc}") from exc

def authorize_permissions(ec2, gid: str, perms: List[Dict[str, Any]], direction: str, dry_run: bool) -> None:

    if not perms:

        return

    if dry_run:

        log(f"[DRY-RUN] Would authorize {direction} on {gid}: {json.dumps(perms, default=str)}")

        return

    try:

        if direction == "ingress":

            retry_aws(lambda: ec2.authorize_security_group_ingress(GroupId=gid, IpPermissions=perms))

        else:

            retry_aws(lambda: ec2.authorize_security_group_egress(GroupId=gid, IpPermissions=perms))

    except ClientError as exc:

        msg = str(exc)

        code = exc.response.get("Error", {}).get("Code", "")

        if "InvalidPermission.Duplicate" in msg or code == "InvalidPermission.Duplicate":

            log(f"[WARN] Duplicate {direction} permission ignored on {gid}")

            return

        raise RuntimeError(f"Failed authorizing {direction} on {gid}: {exc}") from exc

