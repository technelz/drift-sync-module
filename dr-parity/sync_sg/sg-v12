PRINT_LOCK = threading.Lock()

def log(msg: str) -> None:

    with PRINT_LOCK:

        print(msg, flush=True)

def eprint(msg: str) -> None:

    with PRINT_LOCK:

        print(msg, file=sys.stderr, flush=True)

