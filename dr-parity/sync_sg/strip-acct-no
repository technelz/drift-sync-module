def create_or_get_target_sg(ec2, sg: Dict[str, Any], target_vpc_id: str, dry_run: bool) -> str:
    raw_name = sg["GroupName"]
    wanted_name = normalize_sg_name(raw_name)

    existing = describe_sgs_by_vpc(ec2, target_vpc_id)
    for candidate in existing:
        if normalize_sg_name(candidate["GroupName"]) == wanted_name:
            return candidate["GroupId"]

    if dry_run:
        log(f"[DRY-RUN] Would create SG: {raw_name}")
        return f"dryrun-{raw_name}"

    resp = ec2.create_security_group(
        GroupName=raw_name,
        Description=sg.get("Description", raw_name)[:255],
        VpcId=target_vpc_id,
    )
    sg_id = resp["GroupId"]
    log(f"[CREATE] SG {raw_name} -> {sg_id}")
    return sg_id