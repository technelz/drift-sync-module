#!/usr/bin/env python3
"""
Sync AWS Security Groups from source to target.

Supports either:
1) Live source pull from AWS using source profile/region/vpc
2) Existing JSON file from `aws ec2 describe-security-groups`

Examples:

python3 sync_sgs.py \
  --json-path ./sg-export.json \
  --target-profile dr-profile \
  --target-region us-east-2 \
  --target-vpc-id vpc-081d7ae01e6d85d22 \
  --dry-run

python3 sync_sgs.py \
  --source-profile prod-profile \
  --source-region us-east-1 \
  --source-vpc-id vpc-07e9b545595333c38 \
  --target-profile dr-profile \
  --target-region us-east-2 \
  --target-vpc-id vpc-081d7ae01e6d85d22

Friendly alias mode:

python3 sync_sgs.py \
  --prod-profile prod-profile \
  --prod-region us-east-1 \
  --prod-vpc-id vpc-07e9b545595333c38 \
  --dr-profile dr-profile \
  --dr-region us-east-2 \
  --dr-vpc-id vpc-081d7ae01e6d85d22

Requires:
  pip install boto3
"""

from __future__ import annotations

import argparse
import json
import sys
from dataclasses import dataclass, field
from typing import Any, Dict, List, Optional, Tuple

import boto3
from botocore.exceptions import ClientError


# ---------------------------------------------------------
# logging
# ---------------------------------------------------------

def log(msg: str) -> None:
    print(msg, flush=True)


def eprint(msg: str) -> None:
    print(msg, file=sys.stderr, flush=True)


# ---------------------------------------------------------
# aws helpers
# ---------------------------------------------------------

def boto3_session(profile: str, region: str):
    return boto3.Session(profile_name=profile, region_name=region)


def get_ec2(profile: str, region: str):
    return boto3_session(profile, region).client("ec2")


# ---------------------------------------------------------
# models
# ---------------------------------------------------------

@dataclass
class Args:
    json_path: Optional[str]

    source_profile: Optional[str]
    source_region: Optional[str]
    source_vpc_id: Optional[str]

    target_profile: str
    target_region: str
    target_vpc_id: str

    dry_run: bool
    report_only: bool
    yes: bool


@dataclass
class SgAuditResult:
    group_name: str
    source_group_id: Optional[str] = None
    target_group_id: Optional[str] = None
    exists_in_target: bool = False
    description_match: bool = True
    tags_match: bool = True
    ingress_match: bool = True
    egress_match: bool = True
    missing: List[str] = field(default_factory=list)
    drift_fields: List[str] = field(default_factory=list)
    notes: List[str] = field(default_factory=list)

    @property
    def in_sync(self) -> bool:
        return (
            self.exists_in_target
            and self.description_match
            and self.tags_match
            and self.ingress_match
            and self.egress_match
        )


# ---------------------------------------------------------
# parsing / normalization helpers
# ---------------------------------------------------------

SYSTEM_TAG_KEYS_TO_IGNORE = {
    # extend if needed
}


def normalize_args(ns: argparse.Namespace) -> Args:
    source_profile = ns.source_profile or ns.prod_profile
    source_region = ns.source_region or ns.prod_region
    source_vpc_id = ns.source_vpc_id or ns.prod_vpc_id

    target_profile = ns.target_profile or ns.dr_profile
    target_region = ns.target_region or ns.dr_region
    target_vpc_id = ns.target_vpc_id or ns.dr_vpc_id

    if not target_profile or not target_region or not target_vpc_id:
        raise SystemExit(
            "Target/DR values are required. Provide either "
            "--target-profile/--target-region/--target-vpc-id or "
            "--dr-profile/--dr-region/--dr-vpc-id."
        )

    if not ns.json_path:
        missing = []
        if not source_profile:
            missing.append("source/prod profile")
        if not source_region:
            missing.append("source/prod region")
        if not source_vpc_id:
            missing.append("source/prod vpc id")
        if missing:
            raise SystemExit(
                "Either --json-path must be provided, or all source/prod values must be set. "
                f"Missing: {', '.join(missing)}"
            )

    return Args(
        json_path=ns.json_path,
        source_profile=source_profile,
        source_region=source_region,
        source_vpc_id=source_vpc_id,
        target_profile=target_profile,
        target_region=target_region,
        target_vpc_id=target_vpc_id,
        dry_run=ns.dry_run,
        report_only=ns.report_only,
        yes=ns.yes,
    )


def canonical_tags(tags: Optional[List[Dict[str, str]]]) -> List[Tuple[str, str]]:
    out: List[Tuple[str, str]] = []
    for t in tags or []:
        key = t.get("Key", "")
        val = t.get("Value", "")
        if key and key not in SYSTEM_TAG_KEYS_TO_IGNORE:
            out.append((key, val))
    return sorted(out)


def tags_to_aws_payload(tags: List[Tuple[str, str]]) -> List[Dict[str, str]]:
    return [{"Key": k, "Value": v} for k, v in tags]


def is_default_sg(sg: Dict[str, Any]) -> bool:
    return sg.get("GroupName") == "default"


# ---------------------------------------------------------
# source loading
# ---------------------------------------------------------

def load_json_security_groups(path: str) -> List[Dict[str, Any]]:
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)

    if isinstance(data, dict) and "SecurityGroups" in data:
        groups = data["SecurityGroups"]
    elif isinstance(data, list):
        groups = data
    else:
        raise ValueError("Unsupported SG JSON format. Expected either {'SecurityGroups': [...]} or [...]")

    if not isinstance(groups, list):
        raise ValueError("Security groups payload is not a list")

    return groups


def describe_security_groups_by_vpc(ec2, vpc_id: str) -> List[Dict[str, Any]]:
    paginator = ec2.get_paginator("describe_security_groups")
    out: List[Dict[str, Any]] = []
    for page in paginator.paginate(Filters=[{"Name": "vpc-id", "Values": [vpc_id]}]):
        out.extend(page.get("SecurityGroups", []))
    return out


def fetch_source_security_groups(args: Args) -> List[Dict[str, Any]]:
    if args.json_path:
        log(f"[INFO] Loading source security groups from JSON: {args.json_path}")
        return load_json_security_groups(args.json_path)

    assert args.source_profile and args.source_region and args.source_vpc_id
    log(
        f"[INFO] Pulling source security groups from AWS "
        f"(profile={args.source_profile}, region={args.source_region}, vpc={args.source_vpc_id})"
    )
    ec2 = get_ec2(args.source_profile, args.source_region)
    return describe_security_groups_by_vpc(ec2, args.source_vpc_id)


# ---------------------------------------------------------
# target inventory
# ---------------------------------------------------------

def get_target_sg_map(ec2, vpc_id: str) -> Dict[str, Dict[str, Any]]:
    groups = describe_security_groups_by_vpc(ec2, vpc_id)
    return {sg["GroupName"]: sg for sg in groups}


