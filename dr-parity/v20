# --------------------------------------------------------------------

# Logging

# --------------------------------------------------------------------

PRINT_LOCK = threading.Lock()

def log(msg: str) -> None:

    with PRINT_LOCK:

        print(msg, flush=True)

def eprint(msg: str) -> None:

    with PRINT_LOCK:

        print(msg, file=sys.stderr, flush=True)

# --------------------------------------------------------------------

# Constants

# --------------------------------------------------------------------

SYSTEM_TAG_KEYS_TO_IGNORE = {

    "aws:cloudformation:logical-id",

    "aws:cloudformation:stack-id",

    "aws:cloudformation:stack-name",

}

DEFAULT_WORKERS = 4

DEFAULT_REPORTS_DIR = "reports"

# --------------------------------------------------------------------

# Dataclasses

# --------------------------------------------------------------------

@dataclass

class Args:

    json_path: str

    target_profile: str

    target_region: str

    target_vpc_id: str

    dry_run: bool

    report_only: bool

    yes: bool

    name_preview: bool

    workers: int

    rollback_on_error: bool

    report_path: str

@dataclass

class SgAuditResult:

    group_name: str

    source_group_id: Optional[str] = None

    target_group_id: Optional[str] = None

    exists_in_target: bool = False

    description_match: bool = True

    tags_match: bool = True

    ingress_match: bool = True

    egress_match: bool = True

    missing: List[str] = field(default_factory=list)

    drift_fields: List[str] = field(default_factory=list)

    notes: List[str] = field(default_factory=list)

    @property

    def in_sync(self) -> bool:

        return (

            self.exists_in_target

            and self.description_match

            and self.tags_match

            and self.ingress_match

            and self.egress_match

        )

@dataclass

class SgSnapshot:

    group_id: str

    group_name: str

    description: str

    tags: List[Tuple[str, str]]

    ingress: List[Dict[str, Any]]

    egress: List[Dict[str, Any]]

