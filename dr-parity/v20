def main() -> int:

    args = parse_args()

    try:

        source_groups = load_json_security_groups(args.json_path)

    except Exception as exc:

        eprint(f"[ERROR] Failed to load source JSON: {exc}")

        return 1

    source_groups = [sg for sg in source_groups if not is_default_sg(sg)]

    src_acct = extract_source_account_id_from_json(source_groups)

    tgt_acct = None

    log(f"[INFO] Validating target AWS profile: {args.target_profile}")

    try:

        tgt_acct = get_account_id(args.target_profile, args.target_region)

    except Exception as exc:

        eprint(f"[ERROR] Failed to validate target AWS access: {exc}")

        return 1

    log(f"[INFO] Source JSON: {args.json_path}")

    log(f"[INFO] Source account (best effort from JSON): {src_acct}")

    log(f"[INFO] Target account: {tgt_acct}")

    log(f"[INFO] Target region: {args.target_region}")

    log(f"[INFO] Target VPC: {args.target_vpc_id}")

    log(f"[INFO] Worker count: {args.workers}")

    log(f"[INFO] Source SG count (excluding default): {len(source_groups)}")

    log(f"[INFO] Report path: {args.report_path}")

    if args.name_preview:

        print_name_preview(source_groups, src_acct, tgt_acct)

        return 0

    if not args.dry_run and not args.report_only and not args.yes:

        confirm = input(

            "⚠️  This will modify security groups in the target account. "

            "Type 'yes' to continue: "

        )

        if confirm.strip().lower() != "yes":

            print("Aborted.")

            return 1

    try:

        ec2_tgt = get_ec2(args.target_profile, args.target_region)

        tgt_map = get_target_sg_map(ec2_tgt, args.target_vpc_id, src_acct, tgt_acct)

        src_id_to_name = {

            sg["GroupId"]: sg["GroupName"]

            for sg in source_groups

            if sg.get("GroupId")

        }

        ensure_all_target_sgs_exist(source_groups, ec2_tgt, tgt_map, src_acct, tgt_acct, args)

        if not args.dry_run:

            tgt_map = get_target_sg_map(ec2_tgt, args.target_vpc_id, src_acct, tgt_acct)

        tgt_name_to_id = {name: sg["GroupId"] for name, sg in tgt_map.items()}

        audit_results = parallel_reconcile(

            source_groups=source_groups,

            ec2_tgt=ec2_tgt,

            tgt_map=tgt_map,

            src_id_to_name=src_id_to_name,

            tgt_name_to_id=tgt_name_to_id,

            src_acct=src_acct,

            tgt_acct=tgt_acct,

            args=args,

        )

        print_summary(audit_results)

        print_audit_report(audit_results)

        write_json_report(audit_results, args.report_path)

        return 0

    except Exception as exc:

        eprint(f"[ERROR] Sync failed: {exc}")

        return 1

if __name__ == "__main__":

    sys.exit(main())
