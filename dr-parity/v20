# AWS Helpers

# --------------------------------------------------------------------

def retry_aws(func, retries: int = 5, base_sleep: float = 1.0):

    last_exc = None

    for attempt in range(retries):

        try:

            return func()

        except ClientError as exc:

            last_exc = exc

            code = exc.response.get("Error", {}).get("Code", "")

            retriable = code in {

                "RequestLimitExceeded",

                "Throttling",

                "ThrottlingException",

                "InternalError",

                "ServiceUnavailable",

                "Unavailable",

            }

            if not retriable or attempt == retries - 1:

                raise

            sleep_for = base_sleep * (2 ** attempt)

            log(f"[RETRY] AWS call failed with {code}, retrying in {sleep_for:.1f}s")

            time.sleep(sleep_for)

    raise last_exc

def boto3_session(profile: str, region: str):

    return boto3.Session(profile_name=profile, region_name=region)

def get_ec2(profile: str, region: str):

    return boto3_session(profile, region).client("ec2")

def get_sts(profile: str, region: str):

    return boto3_session(profile, region).client("sts")

def get_account_id(profile: str, region: str) -> str:

    sts = get_sts(profile, region)

    ident = retry_aws(lambda: sts.get_caller_identity())

    return ident["Account"]

# --------------------------------------------------------------------

# CLI / Report path helpers

# --------------------------------------------------------------------

def auto_report_path(json_path: str, target_profile: str, target_region: str) -> str:

    reports_dir = Path(DEFAULT_REPORTS_DIR)

    reports_dir.mkdir(parents=True, exist_ok=True)

    base = Path(json_path).stem

    return str(reports_dir / f"{base}_{target_profile}_{target_region}_sg_sync_report.json")

def parse_args() -> Args:

    parser = argparse.ArgumentParser(

        description=(

            "Sync AWS Security Groups from a source JSON export into a target DR account/VPC. "

            "Source/Prod is supplied as --json-path. Target/DR is supplied as target CLI args."

        )

    )

    parser.add_argument(

        "--json-path",

        required=True,

        help="Path to exported source/Prod security groups JSON file.",

    )

    parser.add_argument(

        "--target-profile",

        required=True,

        help="AWS CLI profile for the target/DR account.",

    )

    parser.add_argument(

        "--target-region",

        required=True,

        help="AWS region for the target/DR account.",

    )

    parser.add_argument(

        "--target-vpc-id",

        required=True,

        help="Target/DR VPC ID where security groups will be created/synced.",

    )

    parser.add_argument(

        "--dry-run",

        action="store_true",

        help="Preview changes only. No modifications are made.",

    )

    parser.add_argument(

        "--report-only",

        action="store_true",

        help="Audit only. Compare source vs target without modifying target.",

    )

    parser.add_argument(

        "--yes",

        action="store_true",

        help="Skip confirmation prompt for live execution.",

    )

    parser.add_argument(

        "--name-preview",

        action="store_true",

        help="Show source-to-target SG name mapping and exit.",

    )

    parser.add_argument(

        "--workers",

        type=int,

        default=DEFAULT_WORKERS,

        help=f"Parallel worker count for reconciliation. Default: {DEFAULT_WORKERS}",

    )

    parser.add_argument(

        "--no-rollback",

        action="store_true",

        help="Disable automatic rollback on live failure.",

    )

    parser.add_argument(

        "--report-path",

        help="Optional custom path for the JSON report. If omitted, auto-generated under reports/.",

    )

    ns = parser.parse_args()

    json_path = ns.json_path

    if not Path(json_path).is_file():

        parser.error(f"JSON source file not found: {json_path}")

    workers = max(1, int(ns.workers))

    rollback_on_error = not ns.no_rollback

    report_path = ns.report_path or auto_report_path(json_path, ns.target_profile, ns.target_region)

    # ensure parent dir exists even for custom report path

    Path(report_path).parent.mkdir(parents=True, exist_ok=True)

    return Args(

        json_path=json_path,

        target_profile=ns.target_profile,

        target_region=ns.target_region,

        target_vpc_id=ns.target_vpc_id,

        dry_run=ns.dry_run,

        report_only=ns.report_only,

        yes=ns.yes,

        name_preview=ns.name_preview,

        workers=workers,

        rollback_on_error=rollback_on_error,

        report_path=report_path,

    )

# --------------------------------------------------------------------

# Tag Helpers

# --------------------------------------------------------------------

def canonical_tags(tags: Optional[List[Dict[str, str]]]) -> List[Tuple[str, str]]:

    out: List[Tuple[str, str]] = []

    for t in tags or []:

        key = t.get("Key", "")

        val = t.get("Value", "")

        if key and key not in SYSTEM_TAG_KEYS_TO_IGNORE:

            out.append((key, val))

    return sorted(out)

def tags_to_aws_payload(tags: List[Tuple[str, str]]) -> List[Dict[str, str]]:

    return [{"Key": k, "Value": v} for k, v in tags]

# --------------------------------------------------------------------

# Normalization

# --------------------------------------------------------------------

def is_default_sg(sg: Dict[str, Any]) -> bool:

    return sg.get("GroupName") == "default"

def normalize_sg_name(name: str, src_acct: Optional[str], tgt_acct: Optional[str]) -> str:

    if not src_acct or not tgt_acct or src_acct == tgt_acct:

        return name

    return name.replace(src_acct, tgt_acct, 1)

# --------------------------------------------------------------------

# Source Loading / Target Inventory

# --------------------------------------------------------------------

def load_json_security_groups(path: str) -> List[Dict[str, Any]]:

    with open(path, "r", encoding="utf-8") as f:

        data = json.load(f)

    if isinstance(data, dict) and "SecurityGroups" in data:

        if not isinstance(data["SecurityGroups"], list):

            raise ValueError("JSON 'SecurityGroups' must be a list")

        return data["SecurityGroups"]

    if isinstance(data, list):

        return data

    raise ValueError("Invalid JSON format for SG list")

def extract_source_account_id_from_json(source_groups: List[Dict[str, Any]]) -> Optional[str]:

    """

    Best-effort extraction of source account ID from JSON SG data.

    Uses OwnerId if present on SG, otherwise first UserIdGroupPair UserId if present.

    """

    for sg in source_groups:

        owner = sg.get("OwnerId")

        if owner and str(owner).isdigit():

            return str(owner)

    for sg in source_groups:

        for perm_key in ("IpPermissions", "IpPermissionsEgress"):

            for perm in sg.get(perm_key, []) or []:

                for pair in perm.get("UserIdGroupPairs", []) or []:

                    uid = pair.get("UserId")

                    if uid and str(uid).isdigit():

                        return str(uid)

    return None

def describe_security_groups_by_vpc(ec2, vpc_id: str) -> List[Dict[str, Any]]:

    paginator = ec2.get_paginator("describe_security_groups")

    out: List[Dict[str, Any]] = []

    for page in paginator.paginate(Filters=[{"Name": "vpc-id", "Values": [vpc_id]}]):

        out.extend(page.get("SecurityGroups", []))

    return out

def get_target_sg_map(

    ec2,

    vpc_id: str,

    src_acct: Optional[str],

    tgt_acct: str,

) -> Dict[str, Dict[str, Any]]:

    groups = describe_security_groups_by_vpc(ec2, vpc_id)

    out: Dict[str, Dict[str, Any]] = {}

    for sg in groups:

        raw = sg["GroupName"]

        canon = normalize_sg_name(raw, src_acct, tgt_acct)

        out[canon] = sg

    return out

def print_name_preview(source_groups: List[Dict[str, Any]], src_acct: Optional[str], tgt_acct: Optional[str]) -> None:

    print("=" * 70)

    print("SECURITY GROUP NAME PREVIEW")

    print("=" * 70)

    for sg in source_groups:

        raw = sg["GroupName"]

        new = normalize_sg_name(raw, src_acct, tgt_acct)

        print(f"{raw}\n  -> {new}\n")

    print("=" * 70)

    print("No changes made. Preview only.")

    print("=" * 70 + "\n")

# --------------------------------------------------------------------

# Permission Normalization

# --------------------------------------------------------------------

def map_user_group_pairs(

    pairs: List[Dict[str, Any]],

    src_id_to_name: Dict[str, str],

    tgt_name_to_id: Dict[str, str],

    src_acct: Optional[str],

    tgt_acct: str,

) -> Tuple[List[Dict[str, Any]], List[str]]:

    mapped: List[Dict[str, Any]] = []

    unresolved: List[str] = []

    for pair in pairs or []:

        gid = pair.get("GroupId")

        if not gid:

            unresolved.append("UserIdGroupPair missing GroupId")

            continue

        name = src_id_to_name.get(gid)

        if not name:

            unresolved.append(f"No source SG name for {gid}")

            continue

        canon = normalize_sg_name(name, src_acct, tgt_acct)

        tgt_gid = tgt_name_to_id.get(canon)

        if not tgt_gid:

            unresolved.append(f"No target SG for {canon}")

            continue

        new_pair = {"GroupId": tgt_gid}

        if pair.get("Description") is not None:

            new_pair["Description"] = pair["Description"]

        mapped.append(new_pair)

    return sorted(mapped, key=lambda x: x["GroupId"]), unresolved

def normalize_permission(

    perm: Dict[str, Any],

    src_id_to_name: Dict[str, str],

    tgt_name_to_id: Dict[str, str],

    src_acct: Optional[str],

    tgt_acct: str,

) -> Tuple[Dict[str, Any], List[str]]:

    unresolved: List[str] = []

    norm: Dict[str, Any] = {"IpProtocol": perm.get("IpProtocol")}

    if perm.get("FromPort") is not None:

        norm["FromPort"] = perm["FromPort"]

    if perm.get("ToPort") is not None:

        norm["ToPort"] = perm["ToPort"]

    def copy_ranges(key: str, cidr_key: str) -> List[Dict[str, Any]]:

        out = []

        for item in perm.get(key, []) or []:

            entry = {cidr_key: item[cidr_key]}

            if item.get("Description") is not None:

                entry["Description"] = item["Description"]

            out.append(entry)

        return sorted(out, key=lambda x: (x.get(cidr_key), x.get("Description", "")))

    norm["IpRanges"] = copy_ranges("IpRanges", "CidrIp")

    norm["Ipv6Ranges"] = copy_ranges("Ipv6Ranges", "CidrIpv6")

    norm["PrefixListIds"] = copy_ranges("PrefixListIds", "PrefixListId")

    mapped, unr = map_user_group_pairs(

        perm.get("UserIdGroupPairs", []),

        src_id_to_name,

        tgt_name_to_id,

        src_acct,

        tgt_acct,

    )

    if mapped:

        norm["UserIdGroupPairs"] = mapped

    unresolved.extend(unr)

    return norm, unresolved

def normalize_permissions(

    perms: List[Dict[str, Any]],

    src_id_to_name: Dict[str, str],

    tgt_name_to_id: Dict[str, str],

    src_acct: Optional[str],

    tgt_acct: str,

) -> Tuple[List[Dict[str, Any]], List[str]]:

    out: List[Dict[str, Any]] = []

    unresolved: List[str] = []

    for p in perms or []:

        norm, unr = normalize_permission(p, src_id_to_name, tgt_name_to_id, src_acct, tgt_acct)

        out.append(norm)

        unresolved.extend(unr)

    out = sorted(out, key=lambda x: json.dumps(x, sort_keys=True))

    return out, unresolved

def diff_permissions(

    desired: List[Dict[str, Any]],

    current: List[Dict[str, Any]],

) -> Tuple[List[Dict[str, Any]], List[Dict[str, Any]]]:

    to_add = [p for p in desired if p not in current]

    to_remove = [p for p in current if p not in desired]

    return to_add, to_remove

# --------------------------------------------------------------------

# Sync Helpers

# --------------------------------------------------------------------

def create_or_get_sg(

    ec2,

    source_sg: Dict[str, Any],

    vpc_id: str,

    src_acct: Optional[str],

    tgt_acct: str,

    dry_run: bool,

) -> str:

    raw = source_sg["GroupName"]

    name = normalize_sg_name(raw, src_acct, tgt_acct)

    existing = retry_aws(

        lambda: ec2.describe_security_groups(

            Filters=[

                {"Name": "vpc-id", "Values": [vpc_id]},

                {"Name": "group-name", "Values": [name]},

            ]

        )

    ).get("SecurityGroups", [])

    if existing:

        return existing[0]["GroupId"]

    desc = source_sg.get("Description", f"Synced SG: {name}")

    if dry_run:

        log(f"[DRY-RUN] Would create SG: {name}")

        return f"dryrun:{name}"

    try:

        resp = retry_aws(

            lambda: ec2.create_security_group(

                GroupName=name,

                Description=(desc or name)[:255],

                VpcId=vpc_id,

            )

        )

        gid = resp["GroupId"]

        log(f"[CREATE] SG created: {name} ({gid})")

        return gid

    except ClientError as exc:

        code = exc.response.get("Error", {}).get("Code", "")

        if code == "InvalidGroup.Duplicate":

            existing = retry_aws(

                lambda: ec2.describe_security_groups(

                    Filters=[

                        {"Name": "vpc-id", "Values": [vpc_id]},

                        {"Name": "group-name", "Values": [name]},

                    ]

                )

            ).get("SecurityGroups", [])

            if existing:

                return existing[0]["GroupId"]

        raise

def sync_tags(ec2, gid: str, desired: List[Tuple[str, str]], current: List[Tuple[str, str]], dry_run: bool) -> None:

    if desired == current:

        return

    log(f"[SYNC] Tags differ for {gid}")

    if dry_run:

        log(f"[DRY-RUN] Current tags: {current}")

        log(f"[DRY-RUN] Desired tags: {desired}")

        return

    if desired:

        retry_aws(lambda: ec2.create_tags(Resources=[gid], Tags=tags_to_aws_payload(desired)))

    current_keys = {k for k, _ in current}

    desired_keys = {k for k, _ in desired}

    to_remove = current_keys - desired_keys

    if to_remove:

        retry_aws(

            lambda: ec2.delete_tags(

                Resources=[gid],

                Tags=[{"Key": k} for k in sorted(to_remove)],

            )

        )

def revoke_permissions(ec2, gid: str, perms: List[Dict[str, Any]], direction: str, dry_run: bool) -> None:

    if not perms:

        return

    if dry_run:

        log(f"[DRY-RUN] Would revoke {direction} on {gid}: {json.dumps(perms, default=str)}")

        return

    try:

        if direction == "ingress":

            retry_aws(lambda: ec2.revoke_security_group_ingress(GroupId=gid, IpPermissions=perms))

        else:

            retry_aws(lambda: ec2.revoke_security_group_egress(GroupId=gid, IpPermissions=perms))

    except ClientError as exc:

        raise RuntimeError(f"Failed revoking {direction} on {gid}: {exc}") from exc

def authorize_permissions(ec2, gid: str, perms: List[Dict[str, Any]], direction: str, dry_run: bool) -> None:

    if not perms:

        return

    if dry_run:

        log(f"[DRY-RUN] Would authorize {direction} on {gid}: {json.dumps(perms, default=str)}")

        return

    try:

        if direction == "ingress":

            retry_aws(lambda: ec2.authorize_security_group_ingress(GroupId=gid, IpPermissions=perms))

        else:

            retry_aws(lambda: ec2.authorize_security_group_egress(GroupId=gid, IpPermissions=perms))

    except ClientError as exc:

        msg = str(exc)

        code = exc.response.get("Error", {}).get("Code", "")

        if "InvalidPermission.Duplicate" in msg or code == "InvalidPermission.Duplicate":

            log(f"[WARN] Duplicate {direction} permission ignored on {gid}")

            return

        raise RuntimeError(f"Failed authorizing {direction} on {gid}: {exc}") from exc

