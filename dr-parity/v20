def audit_sg(

    source_sg: Dict[str, Any],

    src_desc: str,

    src_tags: List[Tuple[str, str]],

    src_ing: List[Dict[str, Any]],

    src_eg: List[Dict[str, Any]],

    tgt_sg: Optional[Dict[str, Any]],

    tgt_desc: str,

    tgt_tags: List[Tuple[str, str]],

    tgt_ing: List[Dict[str, Any]],

    tgt_eg: List[Dict[str, Any]],

) -> SgAuditResult:

    r = SgAuditResult(

        group_name=source_sg["GroupName"],

        source_group_id=source_sg.get("GroupId"),

        target_group_id=tgt_sg.get("GroupId") if tgt_sg else None,

        exists_in_target=bool(tgt_sg),

    )

    if not tgt_sg:

        r.missing.append("Missing in target")

        return r

    if src_desc != tgt_desc:

        r.description_match = False

        r.drift_fields.append("Description")

    if src_tags != tgt_tags:

        r.tags_match = False

        r.drift_fields.append("Tags")

    if src_ing != tgt_ing:

        r.ingress_match = False

        r.drift_fields.append("Ingress")

    if src_eg != tgt_eg:

        r.egress_match = False

        r.drift_fields.append("Egress")

    return r

def print_summary(results: List[SgAuditResult]) -> None:

    total = len(results)

    in_sync = sum(1 for r in results if r.in_sync)

    out_sync = total - in_sync

    missing = [r for r in results if not r.exists_in_target]

    drift = [r for r in results if r.exists_in_target and not r.in_sync]

    print("\n" + "=" * 80)

    print("SECURITY GROUP SYNC SUMMARY")

    print("=" * 80)

    print(f"Total SGs processed : {total}")

    print(f"In sync             : {in_sync}")

    print(f"Out of sync         : {out_sync}")

    print(f"Missing in target   : {len(missing)}")

    print(f"Drift detected      : {len(drift)}\n")

    if missing:

        print("Missing SGs:")

        for r in missing:

            print(f" - {r.group_name}")

    if drift:

        print("\nSGs with drift:")

        for r in drift:

            fields = ", ".join(r.drift_fields) if r.drift_fields else "Unknown"

            print(f" - {r.group_name} (fields: {fields})")

    print("=" * 80 + "\n")

def print_audit_report(results: List[SgAuditResult]) -> None:

    for r in results:

        print("-" * 80)

        print(f"SG              : {r.group_name}")

        print(f"Source SG ID    : {r.source_group_id}")

        print(f"Target SG ID    : {r.target_group_id}")

        print(f"Exists          : {r.exists_in_target}")

        print(f"Description     : {'OK' if r.description_match else 'MISMATCH'}")

        print(f"Tags            : {'OK' if r.tags_match else 'MISMATCH'}")

        print(f"Ingress         : {'OK' if r.ingress_match else 'MISMATCH'}")

        print(f"Egress          : {'OK' if r.egress_match else 'MISMATCH'}")

        if r.missing:

            print("Missing:")

            for m in r.missing:

                print(f" - {m}")

        if r.drift_fields:

            print("Drift fields:")

            for f in r.drift_fields:

                print(f" - {f}")

        if r.notes:

            print("Notes:")

            for n in r.notes:

                print(f" - {n}")

    print("-" * 80)

# --------------------------------------------------------------------

# Snapshot / Rollback

# --------------------------------------------------------------------

def snapshot_target_sg(

    sg: Dict[str, Any],

    src_id_to_name: Dict[str, str],

    tgt_name_to_id: Dict[str, str],

    src_acct: Optional[str],

    tgt_acct: str,

) -> SgSnapshot:

    ingress, _ = normalize_permissions(

        sg.get("IpPermissions", []),

        src_id_to_name,

        tgt_name_to_id,

        src_acct,

        tgt_acct,

    )

    egress, _ = normalize_permissions(

        sg.get("IpPermissionsEgress", []),

        src_id_to_name,

        tgt_name_to_id,

        src_acct,

        tgt_acct,

    )

    return SgSnapshot(

        group_id=sg["GroupId"],

        group_name=sg["GroupName"],

        description=sg.get("Description", ""),

        tags=canonical_tags(sg.get("Tags")),

        ingress=ingress,

        egress=egress,

    )

def restore_sg_to_snapshot(ec2, snapshot: SgSnapshot, current_sg: Dict[str, Any], dry_run: bool) -> None:

    gid = snapshot.group_id

    current_tags = canonical_tags(current_sg.get("Tags"))

    sync_tags(ec2, gid, snapshot.tags, current_tags, dry_run)

    def passthrough_norm(perms: List[Dict[str, Any]]) -> List[Dict[str, Any]]:

        out = []

        for perm in perms:

            norm: Dict[str, Any] = {"IpProtocol": perm.get("IpProtocol")}

            if perm.get("FromPort") is not None:

                norm["FromPort"] = perm["FromPort"]

            if perm.get("ToPort") is not None:

                norm["ToPort"] = perm["ToPort"]

            def copy_ranges(key: str, cidr_key: str) -> List[Dict[str, Any]]:

                items = []

                for x in perm.get(key, []) or []:

                    item = {cidr_key: x[cidr_key]}

                    if x.get("Description") is not None:

                        item["Description"] = x["Description"]

                    items.append(item)

                return sorted(items, key=lambda z: (z.get(cidr_key), z.get("Description", "")))

            norm["IpRanges"] = copy_ranges("IpRanges", "CidrIp")

            norm["Ipv6Ranges"] = copy_ranges("Ipv6Ranges", "CidrIpv6")

            norm["PrefixListIds"] = copy_ranges("PrefixListIds", "PrefixListId")

            ugp = []

            for pair in perm.get("UserIdGroupPairs", []) or []:

                if pair.get("GroupId"):

                    item = {"GroupId": pair["GroupId"]}

                    if pair.get("Description") is not None:

                        item["Description"] = pair["Description"]

                    ugp.append(item)

            if ugp:

                norm["UserIdGroupPairs"] = sorted(ugp, key=lambda z: z["GroupId"])

            out.append(norm)

        return sorted(out, key=lambda x: json.dumps(x, sort_keys=True))

    current_ing_norm = passthrough_norm(current_sg.get("IpPermissions", []) or [])

    current_eg_norm = passthrough_norm(current_sg.get("IpPermissionsEgress", []) or [])

    to_add_ing, to_remove_ing = diff_permissions(snapshot.ingress, current_ing_norm)

    to_add_eg, to_remove_eg = diff_permissions(snapshot.egress, current_eg_norm)

    revoke_permissions(ec2, gid, to_remove_ing, "ingress", dry_run)

    authorize_permissions(ec2, gid, to_add_ing, "ingress", dry_run)

    revoke_permissions(ec2, gid, to_remove_eg, "egress", dry_run)

    authorize_permissions(ec2, gid, to_add_eg, "egress", dry_run)

def rollback_changes(

    ec2,

    snapshots: Dict[str, SgSnapshot],

    changed_group_ids: List[str],

    dry_run: bool,

) -> None:

    log("\n[ROLLBACK] Starting rollback of changed security groups...")

    for gid in reversed(changed_group_ids):

        snapshot = snapshots.get(gid)

        if not snapshot:

            log(f"[ROLLBACK] No snapshot for {gid}; skipping")

            continue

        try:

            sg = retry_aws(lambda: ec2.describe_security_groups(GroupIds=[gid]))["SecurityGroups"][0]

            restore_sg_to_snapshot(ec2, snapshot, sg, dry_run)

            log(f"[ROLLBACK] Restored {snapshot.group_name} ({gid})")

        except Exception as exc:

            eprint(f"[ROLLBACK-ERROR] Failed restoring {gid}: {exc}")

    log("[ROLLBACK] Completed.")

