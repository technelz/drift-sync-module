def main() -> int:

```
args = parse_args()

# ----------------------------
# Load source SGs
# ----------------------------
source_groups = load_json_security_groups(args.json_path)
source_groups = [s for s in source_groups if not is_default_sg(s)]

if not source_groups:
    log("No non-default security groups found.")
    return 0

# ----------------------------
# AWS setup
# ----------------------------
ec2 = get_ec2(args.target_profile, args.target_region)

src_acct = get_account_id(args.target_profile, args.target_region)
tgt_acct = src_acct

log(f"[INFO] Source SGs: {len(source_groups)}")
log(f"[INFO] Target region: {args.target_region}")
log(f"[INFO] Target VPC: {args.target_vpc_id}")

# ----------------------------
# Target SG map
# ----------------------------
tgt_map = get_target_sg_map(ec2, args.target_vpc_id, src_acct, tgt_acct)

# ----------------------------
# Preview mode
# ----------------------------
if args.name_preview:
    for sg in source_groups:
        raw = sg["GroupName"]
        canon = normalize_sg_name(raw, src_acct, tgt_acct)
        log(f"{raw} -> {canon}")
    return 0

# ----------------------------
# PLAN BUILD
# ----------------------------
plan = build_plan(
    source_groups=source_groups,
    target_map=tgt_map,
    src_acct=src_acct,
    tgt_acct=tgt_acct
)

results = plan.changes

# ----------------------------
# OUTPUT
# ----------------------------
print_summary(results)
write_report(args.report_path, results)

# ----------------------------
# EXIT CODE
# ----------------------------
return compute_exit_code(results)
```

