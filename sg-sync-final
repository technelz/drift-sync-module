# NORMALIZATION (FIXED, SAFE, NON-DESTRUCTIVE)

# ——————————————————————————

def normalize_sg_name(name: str, src_acct: str, tgt_acct: str) -> str:
“””
Robust multi-stage normalization for SG names.
Handles:
- CFN stack prefixes (stack-<anything>-<LogicalID>-<hash>)
- Environment prefixes (d-xxxxxx-, prod-, dev-, qa-, etc.)
- Account prefixes
- Random suffixes
- Mixed separators
- Case normalization
“””

```
original = name

# 1. Replace embedded account ID if different
if src_acct and tgt_acct and src_acct != tgt_acct:
    name = name.replace(src_acct, tgt_acct)

# 2. Lowercase everything early
name = name.lower()

# 3. Strip ANY CloudFormation stack prefix (multi-segment, mixed case)
#    Example: stack-abc123-nested-xyz789-rsecuritygroup-labcxyz
name = re.sub(r"^stack-[a-z0-9-]+-", "", name, flags=re.IGNORECASE)

# 4. Strip environment/account prefixes:
#    d-12345665-, prod-, dev-, qa-, uat-, etc.
name = re.sub(
    r"^(d|dev|prod|qa|uat|stage|stg|test|acc|acct|env)-[a-z0-9]+[-_]",
    "",
    name
)

# 5. Strip leading account-number prefixes:
#    123456789012-<name>
name = re.sub(r"^[0-9]{6,12}[-_]", "", name)

# 6. Strip trailing CFN resource hash:
#    <name>-ABC12345
name = re.sub(r"-[a-z0-9]{8,}$", "", name)

# 7. Strip trailing env suffixes:
#    <name>-dev, <name>-prod, <name>-12345
name = re.sub(
    r"-(dev|prod|qa|uat|stage|stg|test|acc|acct|env|[0-9]+)$",
    "",
    name
)

# 8. Collapse multiple separators
# (continuation assumed from image)

# 9. Final cleanup
name = name.strip("-_ ")

return name
```

